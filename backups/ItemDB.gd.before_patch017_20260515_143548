class_name RVItemDB
extends RefCounted

const SLOTS = ["weapon", "offhand", "head", "chest", "gloves", "boots", "amulet", "ring", "relic"]

const AFFIXES = {
	"fire_damage": {"name": "Pyre", "stat": "fire_damage", "family": "ash", "type": "prefix", "base": 0.035},
	"cold_damage": {"name": "Rime", "stat": "cold_damage", "family": "frost", "type": "prefix", "base": 0.035},
	"lightning_damage": {"name": "Static", "stat": "lightning_damage", "family": "storm", "type": "prefix", "base": 0.035},
	"void_damage": {"name": "Abyss", "stat": "void_damage", "family": "void", "type": "prefix", "base": 0.035},
	"melee_damage": {"name": "Butcher", "stat": "melee_damage", "family": "steel", "type": "prefix", "base": 0.040},
	"trap_damage": {"name": "Mechanist", "stat": "trap_damage", "family": "trap", "type": "prefix", "base": 0.040},
	"spell_damage": {"name": "Ritual", "stat": "spell_damage", "family": "blood", "type": "prefix", "base": 0.030},
	"global_damage": {"name": "Relic", "stat": "global_damage", "family": "relic", "type": "prefix", "base": 0.025},
	"max_hp": {"name": "Bulwark", "stat": "max_hp", "family": "steel", "type": "suffix", "base": 9.0},
	"max_mana": {"name": "Channel", "stat": "max_mana", "family": "void", "type": "suffix", "base": 7.0},
	"cooldown_reduction": {"name": "Tempo", "stat": "cooldown_reduction", "family": "storm", "type": "suffix", "base": 0.007},
	"spirit": {"name": "Spirit", "stat": "spirit", "family": "relic", "type": "suffix", "base": 2.0}

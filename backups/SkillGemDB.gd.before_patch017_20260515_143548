static func active_skill_names() -> Array:
	return ACTIVE_GEMS.keys()

static func support_names() -> Array:
	return SUPPORT_GEMS.keys()

static func spirit_names() -> Array:
	return SPIRIT_GEMS.keys()

static func active_data(skill: String) -> Dictionary:
	return ACTIVE_GEMS.get(skill, {})

static func support_data(support: String) -> Dictionary:
	return SUPPORT_GEMS.get(support, {})

static func spirit_data(spirit: String) -> Dictionary:
	return SPIRIT_GEMS.get(spirit, {})

static func support_can_attach(support: String, skill: String) -> bool:
	var sd: Dictionary = support_data(support)
	var ad: Dictionary = active_data(skill)
	if sd.is_empty() or ad.is_empty():
		return false
	var required: Array = sd.get("tags", [])
	if required.has("Any"):
		return true
	var tags: Array = ad.get("tags", [])
	for tag in required:
		if tags.has(tag):
			return true
	return false

extends CanvasLayer

# RELIC FORGE: VAULTBOUND — Patch 004A
# Low-intrusion HUD layer.
#
# This UI is intentionally quiet:
# - no giant permanent debug slabs
# - combat info stays at edges
# - build info appears as compact summaries
# - panels are readable but should not invade the play space

var root: Control
var status_panel: PanelContainer
var skill_panel: PanelContainer
var room_panel: PanelContainer
var notice_panel: PanelContainer
var build_panel: PanelContainer
var inventory_panel: PanelContainer
var skilltree_panel: PanelContainer
var dungeon_panel: PanelContainer

var hp_bar: ProgressBar
var mana_bar: ProgressBar
var hp_text: Label
var mana_text: Label
var depth_text: Label
var selected_skill_text: Label
var skill_slot_labels: Array[Label] = []
var room_text: Label
var notice_text: Label
var build_text: Label
var inventory_text: Label
var skilltree_text: Label
var dungeon_text: Label

var last_notice = ""
var notice_timer = 0.0

func _ready() -> void:
	layer = 40
	_build_ui()


func _process(delta: float) -> void:
	if notice_timer > 0.0:
		notice_timer -= delta
		if notice_timer <= 0.0:
			notice_panel.visible = false


func _build_ui() -> void:
	root = Control.new()
	root.name = "LowIntrusionHUDRoot"
	root.set_anchors_preset(Control.PRESET_FULL_RECT)
	add_child(root)

	var quiet_bg = StyleBoxFlat.new()
	quiet_bg.bg_color = Color(0.025, 0.023, 0.026, 0.72)
	quiet_bg.border_color = Color(0.72, 0.60, 0.42, 0.32)
	quiet_bg.set_border_width_all(1)
	quiet_bg.set_corner_radius_all(10)
	quiet_bg.content_margin_left = 10
	quiet_bg.content_margin_right = 10
	quiet_bg.content_margin_top = 8
	quiet_bg.content_margin_bottom = 8

	var quiet_bg_strong = StyleBoxFlat.new()
	quiet_bg_strong.bg_color = Color(0.018, 0.017, 0.020, 0.88)
	quiet_bg_strong.border_color = Color(0.88, 0.70, 0.42, 0.42)
	quiet_bg_strong.set_border_width_all(1)
	quiet_bg_strong.set_corner_radius_all(12)
	quiet_bg_strong.content_margin_left = 12
	quiet_bg_strong.content_margin_right = 12
	quiet_bg_strong.content_margin_top = 10
	quiet_bg_strong.content_margin_bottom = 10

	status_panel = _panel("StatusPanel", quiet_bg)
	status_panel.position = Vector2(18, 592)
	status_panel.custom_minimum_size = Vector2(270, 82)
	root.add_child(status_panel)

	var status_box = VBoxContainer.new()
	status_box.add_theme_constant_override("separation", 4)
	status_panel.add_child(status_box)

	var top_status = HBoxContainer.new()
	top_status.add_theme_constant_override("separation", 8)
	status_box.add_child(top_status)

	hp_text = _label("HP", 12, Color(0.92, 0.86, 0.76))
	top_status.add_child(hp_text)

	depth_text = _label("Depth", 12, Color(0.62, 0.58, 0.50))
	depth_text.horizontal_alignment = HORIZONTAL_ALIGNMENT_RIGHT
	depth_text.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	top_status.add_child(depth_text)

	hp_bar = _bar(0.0, 120.0, 120.0)
	status_box.add_child(hp_bar)

	mana_text = _label("Mana", 12, Color(0.74, 0.82, 0.95))
	status_box.add_child(mana_text)

	mana_bar = _bar(0.0, 100.0, 100.0)
	status_box.add_child(mana_bar)

	skill_panel = _panel("SkillPanel", quiet_bg)
	skill_panel.position = Vector2(380, 604)
	skill_panel.custom_minimum_size = Vector2(520, 70)
	root.add_child(skill_panel)

	var skill_box = VBoxContainer.new()
	skill_box.add_theme_constant_override("separation", 5)
	skill_panel.add_child(skill_box)

	selected_skill_text = _label("No skill selected", 12, Color(0.92, 0.86, 0.76))
	selected_skill_text.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	skill_box.add_child(selected_skill_text)

	var slots = HBoxContainer.new()
	slots.add_theme_constant_override("separation", 6)
	skill_box.add_child(slots)

	for i in range(6):
		var l = _label(str(i + 1) + "  —", 12, Color(0.70, 0.66, 0.58))
		l.custom_minimum_size = Vector2(78, 25)
		l.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		l.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
		l.add_theme_stylebox_override("normal", _slot_style(false))
		skill_slot_labels.append(l)
		slots.add_child(l)

	room_panel = _panel("RoomPanel", quiet_bg)
	room_panel.position = Vector2(390, 16)
	room_panel.custom_minimum_size = Vector2(500, 46)
	root.add_child(room_panel)

	room_text = _label("Room", 12, Color(0.84, 0.80, 0.72))
	room_text.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	room_panel.add_child(room_text)

	notice_panel = _panel("NoticePanel", quiet_bg_strong)
	notice_panel.position = Vector2(430, 76)
	notice_panel.custom_minimum_size = Vector2(420, 42)
	notice_panel.visible = false
	root.add_child(notice_panel)

	notice_text = _label("", 13, Color(1.0, 0.86, 0.55))
	notice_text.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	notice_panel.add_child(notice_text)

	build_panel = _side_panel("BuildPanel", quiet_bg_strong, Vector2(930, 110), Vector2(330, 445))
	build_text = _panel_text(build_panel, "BUILD SUMMARY\n\nPress P to toggle.", 12)

	inventory_panel = _side_panel("InventoryPanel", quiet_bg_strong, Vector2(930, 110), Vector2(330, 445))
	inventory_text = _panel_text(inventory_panel, "INVENTORY\n\nPress I to toggle.", 12)
	inventory_panel.visible = false

	skilltree_panel = _side_panel("SkillTreePanel", quiet_bg_strong, Vector2(880, 88), Vector2(380, 500))
	skilltree_text = _panel_text(skilltree_panel, "SKILL TREE\n\nPress K to toggle.", 12)
	skilltree_panel.visible = false

	dungeon_panel = _side_panel("DungeonPanel", quiet_bg_strong, Vector2(930, 110), Vector2(330, 445))
	dungeon_text = _panel_text(dungeon_panel, "DUNGEON\n\nPress M to toggle.", 12)
	dungeon_panel.visible = false


func _panel(n: String, style: StyleBox) -> PanelContainer:
	var p = PanelContainer.new()
	p.name = n
	p.add_theme_stylebox_override("panel", style)
	return p


func _side_panel(n: String, style: StyleBox, pos: Vector2, min_size: Vector2) -> PanelContainer:
	var p = _panel(n, style)
	p.position = pos
	p.custom_minimum_size = min_size
	root.add_child(p)
	return p


func _panel_text(parent: PanelContainer, text: String, font_size: int) -> Label:
	var l = _label(text, font_size, Color(0.82, 0.78, 0.70))
	l.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
	l.custom_minimum_size = parent.custom_minimum_size - Vector2(22, 18)
	parent.add_child(l)
	return l


func _label(text: String, font_size: int, color: Color) -> Label:
	var l = Label.new()
	l.text = text
	l.add_theme_font_size_override("font_size", font_size)
	l.add_theme_color_override("font_color", color)
	l.clip_text = true
	return l


func _bar(min_v: float, max_v: float, value_v: float) -> ProgressBar:
	var b = ProgressBar.new()
	b.min_value = min_v
	b.max_value = max_v
	b.value = value_v
	b.custom_minimum_size = Vector2(250, 12)
	b.show_percentage = false
	return b


func _slot_style(active: bool) -> StyleBoxFlat:
	var s = StyleBoxFlat.new()
	s.bg_color = Color(0.09, 0.085, 0.09, 0.88)
	s.border_color = Color(0.95, 0.72, 0.36, 0.72) if active else Color(0.50, 0.45, 0.36, 0.30)
	s.set_border_width_all(1)
	s.set_corner_radius_all(7)
	s.content_margin_left = 4
	s.content_margin_right = 4
	s.content_margin_top = 3
	s.content_margin_bottom = 3
	return s


func update_hud(data: Dictionary) -> void:
	var hp = float(data.get("hp", 0.0))
	var hp_max = max(1.0, float(data.get("hp_max", 120.0)))
	var mana = float(data.get("mana", 0.0))
	var mana_max = max(1.0, float(data.get("mana_max", 100.0)))
	var depth = int(data.get("depth", 0))
	var max_depth = int(data.get("max_depth", 16))
	var room_name = str(data.get("room", "Unknown Room"))
	var room_type = str(data.get("room_type", "Combat"))
	var enemies_left = int(data.get("enemies", 0))
	var active_skills: Array = data.get("active_skills", [])
	var selected = int(data.get("selected_skill", 0))
	var cooldowns: Dictionary = data.get("cooldowns", {})
	var mana_costs: Dictionary = data.get("mana_costs", {})
	var panel = str(data.get("panel", "build"))
	var build_summary = str(data.get("build_summary", ""))
	var inventory_summary = str(data.get("inventory_summary", ""))
	var skilltree_summary = str(data.get("skilltree_summary", ""))
	var dungeon_summary = str(data.get("dungeon_summary", ""))

	hp_bar.max_value = hp_max
	hp_bar.value = clamp(hp, 0.0, hp_max)
	mana_bar.max_value = mana_max
	mana_bar.value = clamp(mana, 0.0, mana_max)

	hp_text.text = "HP  " + str(int(hp)) + " / " + str(int(hp_max))
	mana_text.text = "MANA  " + str(int(mana)) + " / " + str(int(mana_max))
	depth_text.text = "D" + str(depth) + "/" + str(max_depth)

	room_text.text = room_type + "  ·  " + room_name + "  ·  enemies " + str(enemies_left)

	for i in range(skill_slot_labels.size()):
		var l: Label = skill_slot_labels[i]
		if i < active_skills.size():
			var skill_name = str(active_skills[i])
			var cd = float(cooldowns.get(skill_name, 0.0))
			var cost = float(mana_costs.get(skill_name, 0.0))
			var cd_text = ""
			if cd > 0.05:
				cd_text = " " + str(snapped(cd, 0.1))
			elif mana < cost:
				cd_text = " no mana"
			l.text = str(i + 1) + "  " + _short_skill(skill_name) + cd_text
			l.add_theme_stylebox_override("normal", _slot_style(i == selected))
			l.add_theme_color_override("font_color", Color(0.95, 0.83, 0.58) if i == selected else Color(0.74, 0.70, 0.62))
		else:
			l.text = str(i + 1) + "  —"
			l.add_theme_stylebox_override("normal", _slot_style(false))
			l.add_theme_color_override("font_color", Color(0.42, 0.39, 0.34))

	if selected >= 0 and selected < active_skills.size():
		selected_skill_text.text = "Selected: " + str(active_skills[selected])
	else:
		selected_skill_text.text = "Choose a skill draft"

	build_panel.visible = panel == "build"
	inventory_panel.visible = panel == "inventory"
	skilltree_panel.visible = panel == "skilltree"
	dungeon_panel.visible = panel == "dungeon"

	if build_summary != "":
		build_text.text = build_summary
	if inventory_summary != "":
		inventory_text.text = inventory_summary
	if skilltree_summary != "":
		skilltree_text.text = skilltree_summary
	if dungeon_summary != "":
		dungeon_text.text = dungeon_summary


func push_notice(text: String) -> void:
	if text == "" or text == last_notice:
		return
	last_notice = text
	notice_text.text = text
	notice_panel.visible = true
	notice_timer = 2.3


func _short_skill(skill_name: String) -> String:
	match skill_name:
		"Fireball":
			return "FIRE"
		"Cleave":
			return "CUT"
		"Frost Nova":
			return "NOVA"
		"Storm Lance":
			return "LANCE"
		"Void Rift":
			return "RIFT"
		"Blade Trap":
			return "TRAP"
		_:
			return skill_name.substr(0, min(5, skill_name.length())).to_upper()

extends RVUIPanelBase

var backpack_grid: Node = null
var equipment_root: Node = null
var detail_label: Label = null
var character_summary: Label = null
var materials_label: Label = null
var equip_button: Button = null
var stash_button: Button = null
var salvage_button: Button = null
var unequip_button: Button = null
var close_button: Button = null

var current_state: RVGameState = null
var backpack_buttons: Array[Button] = []
var equipment_buttons: Dictionary = {}
var detail_source: String = "backpack"

func _ready() -> void:
	super._ready()
	_bind_nodes()
	_collect_buttons()
	_connect_buttons()

func update_from_state(state: RVGameState) -> void:
	current_state = state
	_bind_nodes()
	_collect_buttons()
	_connect_buttons()
	_update_backpack_slots(state)
	_update_equipment_slots(state)
	_update_details(state)
	_update_actions(state)

func _bind_nodes() -> void:
	if backpack_grid == null:
		backpack_grid = _find_node(["BackpackGrid"])
	if equipment_root == null:
		equipment_root = _find_node(["EquipmentSlots", "EquipmentGrid"])
	if detail_label == null:
		detail_label = _find_node(["DetailLabel", "ItemDetailLabel", "SelectedItemLabel"]) as Label
	if character_summary == null:
		character_summary = _find_node(["CharacterSummary", "EquipmentSummary", "EquippedSummary"]) as Label
	if materials_label == null:
		materials_label = _find_node(["MaterialsLabel", "ResourceLabel", "CurrencyLabel"]) as Label
	if equip_button == null:
		equip_button = _find_node(["EquipButton"]) as Button
	if stash_button == null:
		stash_button = _find_node(["StashButton", "StoreButton"]) as Button
	if salvage_button == null:
		salvage_button = _find_node(["SalvageButton", "DismantleButton"]) as Button
	if unequip_button == null:
		unequip_button = _find_node(["UnequipButton"]) as Button
	if close_button == null:
		close_button = _find_node(["CloseButton"]) as Button

func _collect_buttons() -> void:
	backpack_buttons.clear()
	equipment_buttons.clear()
	if backpack_grid != null:
		var found_backpack: Array[Button] = []
		_collect_button_descendants(backpack_grid, found_backpack)
		backpack_buttons = found_backpack
	if equipment_root != null:
		var found_equipment: Array[Button] = []
		_collect_button_descendants(equipment_root, found_equipment)
		for button: Button in found_equipment:
			var slot_name: String = _slot_from_button(button)
			if slot_name != "" and RVInventorySystem.EQUIPMENT_ORDER.has(slot_name):
				equipment_buttons[slot_name] = button

func _connect_buttons() -> void:
	for i: int in range(backpack_buttons.size()):
		var button: Button = backpack_buttons[i]
		if not bool(button.get_meta("rv_backpack_connected", false)):
			button.pressed.connect(_on_backpack_slot_pressed.bind(i))
			button.set_meta("rv_backpack_connected", true)
	for slot_value: Variant in equipment_buttons.keys():
		var slot_name: String = str(slot_value)
		var gear_button: Button = equipment_buttons[slot_name]
		if not bool(gear_button.get_meta("rv_equipment_connected", false)):
			gear_button.pressed.connect(_on_equipment_slot_pressed.bind(slot_name))
			gear_button.set_meta("rv_equipment_connected", true)
	if equip_button != null and not bool(equip_button.get_meta("rv_connected", false)):
		equip_button.pressed.connect(_on_equip_pressed)
		equip_button.set_meta("rv_connected", true)
	if stash_button != null and not bool(stash_button.get_meta("rv_connected", false)):
		stash_button.pressed.connect(_on_stash_pressed)
		stash_button.set_meta("rv_connected", true)
	if salvage_button != null and not bool(salvage_button.get_meta("rv_connected", false)):
		salvage_button.pressed.connect(_on_salvage_pressed)
		salvage_button.set_meta("rv_connected", true)
	if unequip_button != null and not bool(unequip_button.get_meta("rv_connected", false)):
		unequip_button.pressed.connect(_on_unequip_pressed)
		unequip_button.set_meta("rv_connected", true)
	if close_button != null and not bool(close_button.get_meta("rv_connected", false)):
		close_button.pressed.connect(_on_close_pressed)
		close_button.set_meta("rv_connected", true)

func _update_backpack_slots(state: RVGameState) -> void:
	for i: int in range(backpack_buttons.size()):
		var button: Button = backpack_buttons[i]
		if i < state.backpack.size():
			var item: Dictionary = state.backpack[i]
			button.text = _short_item_label(item)
			button.disabled = false
			button.tooltip_text = RVInventorySystem.item_detail_text_with_compare(state, item)
		else:
			button.text = ""
			button.disabled = true
			button.tooltip_text = "Empty"
		button.modulate = Color(1.0, 0.88, 0.58, 1.0) if i == int(state.inventory_cursor) and i < state.backpack.size() else Color.WHITE

func _update_equipment_slots(state: RVGameState) -> void:
	for slot_value: Variant in equipment_buttons.keys():
		var slot_name: String = str(slot_value)
		var button: Button = equipment_buttons[slot_name]
		var item_value: Variant = state.equipped.get(slot_name, {})
		button.disabled = false
		if typeof(item_value) == TYPE_DICTIONARY and not item_value.is_empty():
			button.text = "◆"
			button.tooltip_text = RVInventorySystem.item_detail_text(item_value)
			_set_button_font_color(button, _rarity_color(str(item_value.get("rarity", "Common"))))
			_update_optional_equipped_name_label(slot_name, RVInventorySystem.equipped_short_label(state, slot_name))
		else:
			button.text = ""
			button.tooltip_text = RVInventorySystem._slot_label(slot_name) + ": Empty"
			_set_button_font_color(button, Color.WHITE)
			_update_optional_equipped_name_label(slot_name, "Empty")
		button.modulate = Color(1.0, 0.88, 0.58, 1.0) if RVInventorySystem.EQUIPMENT_ORDER.find(slot_name) == int(state.equipment_cursor) else Color.WHITE

func _update_details(state: RVGameState) -> void:
	if character_summary != null:
		character_summary.text = RVInventorySystem.equipped_summary_text(state)
	if materials_label != null:
		materials_label.text = "Gold %s  Embers %s  Shards %s  Runes %s  Echo Glass %s" % [
			state.gold,
			state.materials.get("embers", 0),
			state.materials.get("shards", 0),
			state.materials.get("runes", 0),
			state.materials.get("echo_glass", 0),
		]
	if detail_label == null:
		return
	var item: Dictionary = {}
	if detail_source == "equipment":
		item = RVInventorySystem.selected_equipped_item(state)
		detail_label.text = RVInventorySystem.item_detail_text(item) if not item.is_empty() else "Select an equipped slot."
	else:
		item = RVInventorySystem.selected_backpack_item(state)
		detail_label.text = RVInventorySystem.item_detail_text_with_compare(state, item) if not item.is_empty() else "Backpack is empty."

func _update_actions(state: RVGameState) -> void:
	var has_backpack_item: bool = not RVInventorySystem.selected_backpack_item(state).is_empty()
	var has_equipped_item: bool = not RVInventorySystem.selected_equipped_item(state).is_empty()
	if equip_button != null:
		equip_button.disabled = not has_backpack_item
	if stash_button != null:
		stash_button.disabled = not has_backpack_item
	if salvage_button != null:
		salvage_button.disabled = not has_backpack_item
	if unequip_button != null:
		unequip_button.disabled = not has_equipped_item

func _on_backpack_slot_pressed(index: int) -> void:
	if current_state == null:
		return
	detail_source = "backpack"
	RVInventorySystem.select_backpack_index(current_state, index)
	_update_backpack_slots(current_state)
	_update_details(current_state)
	_update_actions(current_state)

func _on_equipment_slot_pressed(slot_name: String) -> void:
	if current_state == null:
		return
	detail_source = "equipment"
	RVInventorySystem.select_equipment_slot(current_state, slot_name)
	_update_equipment_slots(current_state)
	_update_details(current_state)
	_update_actions(current_state)

func _on_equip_pressed() -> void:
	if current_state == null:
		return
	RVInventorySystem.equip_selected_backpack_item(current_state)
	detail_source = "equipment"
	update_from_state(current_state)

func _on_stash_pressed() -> void:
	if current_state == null:
		return
	RVInventorySystem.stash_selected_backpack_item(current_state)
	detail_source = "backpack"
	update_from_state(current_state)

func _on_salvage_pressed() -> void:
	if current_state == null:
		return
	RVInventorySystem.salvage_selected_backpack_item(current_state)
	detail_source = "backpack"
	update_from_state(current_state)

func _on_unequip_pressed() -> void:
	if current_state == null:
		return
	RVInventorySystem.unequip_selected_item(current_state)
	detail_source = "backpack"
	update_from_state(current_state)

func _on_close_pressed() -> void:
	if current_state != null:
		current_state.panel_mode = ""

func _short_item_label(item: Dictionary) -> String:
	var rarity: String = str(item.get("rarity", "Common"))
	var name: String = str(item.get("name", "Item"))
	if name.length() > 13:
		name = name.substr(0, 12) + "…"
	return rarity.substr(0, 1) + "\n" + name

func _slot_from_button(button: Button) -> String:
	if button.has_meta("slot"):
		return RVInventorySystem.normalize_slot(str(button.get_meta("slot")))
	var lower_name: String = button.name.to_lower()
	if lower_name.contains("helmet") or lower_name.contains("head"):
		return "head"
	if lower_name.contains("weapon") or lower_name.contains("mainhand"):
		return "weapon"
	if lower_name.contains("offhand") or lower_name.contains("shield"):
		return "offhand"
	if lower_name.contains("chest") or lower_name.contains("armor") or lower_name.contains("body"):
		return "chest"
	if lower_name.contains("glove") or lower_name.contains("hand"):
		return "gloves"
	if lower_name.contains("boot") or lower_name.contains("feet"):
		return "boots"
	if lower_name.contains("amulet") or lower_name.contains("neck"):
		return "amulet"
	if lower_name.contains("ring1") or lower_name.contains("leftring"):
		return "ring1"
	if lower_name.contains("ring2") or lower_name.contains("rightring"):
		return "ring2"
	if lower_name.contains("ring"):
		return "ring1"
	if lower_name.contains("relic") or lower_name.contains("charm"):
		return "relic"
	return RVInventorySystem.normalize_slot(button.name)

func _collect_button_descendants(node: Node, output: Array[Button]) -> void:
	for child: Node in node.get_children():
		if child is Button:
			output.append(child)
		_collect_button_descendants(child, output)

func _find_node(names: Array[String]) -> Node:
	for node_name: String in names:
		var direct: Node = get_node_or_null("%" + node_name)
		if direct != null:
			return direct
		var recursive: Node = _find_descendant_by_name(self, node_name)
		if recursive != null:
			return recursive
	return null

func _find_descendant_by_name(node: Node, target_name: String) -> Node:
	if node.name == target_name:
		return node
	for child: Node in node.get_children():
		var found: Node = _find_descendant_by_name(child, target_name)
		if found != null:
			return found
	return null

func _update_optional_equipped_name_label(slot_name: String, text_value: String) -> void:
	var suffix: String = RVInventorySystem._slot_label(slot_name).replace(" ", "")
	var candidates: Array[String] = [
		"EquippedName" + suffix,
		"ItemName" + suffix,
		"GearName" + suffix,
		"EquippedItem" + suffix,
	]
	for candidate: String in candidates:
		var node: Node = _find_descendant_by_name(self, candidate)
		if node is Label:
			(node as Label).text = text_value
			return

func _set_button_font_color(button: Button, color: Color) -> void:
	button.add_theme_color_override("font_color", color)
	button.add_theme_color_override("font_hover_color", color.lightened(0.15))
	button.add_theme_color_override("font_pressed_color", color.darkened(0.10))
	button.add_theme_color_override("font_disabled_color", Color(0.45, 0.45, 0.45, 0.65))

func _rarity_color(rarity: String) -> Color:
	match rarity:
		"Magic":
			return Color(0.35, 0.62, 1.0)
		"Rare":
			return Color(1.0, 0.78, 0.25)
		"Epic":
			return Color(0.75, 0.38, 1.0)
		"Legendary":
			return Color(1.0, 0.46, 0.14)
		"Crafted":
			return Color(0.30, 0.95, 0.62)
	return Color(0.86, 0.84, 0.78)

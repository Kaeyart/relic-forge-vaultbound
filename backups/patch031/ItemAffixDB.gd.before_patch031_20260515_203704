static func rarity_affix_counts(rarity: String, rng: RandomNumberGenerator) -> Dictionary:
	match rarity:
		"Normal":
			return {"prefixes": 0, "suffixes": 0}
		"Magic":
			if rng.randf() < 0.55:
				return {"prefixes": 1, "suffixes": 1}
			if rng.randf() < 0.5:
				return {"prefixes": 1, "suffixes": 0}
			return {"prefixes": 0, "suffixes": 1}
		"Rare":
			var total: int = rng.randi_range(4, 6)
			var prefixes: int = rng.randi_range(max(1, total - MAX_SUFFIXES), min(MAX_PREFIXES, total - 1))
			var suffixes: int = total - prefixes
			return {"prefixes": prefixes, "suffixes": suffixes}
		_:
			return {"prefixes": 0, "suffixes": 0}

static func generate_affixes(base: Dictionary, rarity: String, item_level: int, rng: RandomNumberGenerator) -> Dictionary:
	var counts: Dictionary = rarity_affix_counts(rarity, rng)
	var prefixes: Array[Dictionary] = []
	var suffixes: Array[Dictionary] = []
	var used: Dictionary = {}
	for i: int in range(int(counts.get("prefixes", 0))):
		var prefix: Dictionary = _roll_affix(PREFIXES, base, item_level, rng, used)
		if not prefix.is_empty():
			prefixes.append(prefix)
			used[str(prefix.get("id", ""))] = true
	for i2: int in range(int(counts.get("suffixes", 0))):
		var suffix: Dictionary = _roll_affix(SUFFIXES, base, item_level, rng, used)
		if not suffix.is_empty():
			suffixes.append(suffix)
			used[str(suffix.get("id", ""))] = true
	return {"prefixes": prefixes, "suffixes": suffixes}

static func _roll_affix(pool: Array[Dictionary], base: Dictionary, item_level: int, rng: RandomNumberGenerator, used: Dictionary) -> Dictionary:
	var candidates: Array[Dictionary] = []
	var total_weight: int = 0
	for affix: Dictionary in pool:
		var affix_id: String = str(affix.get("id", ""))
		if used.has(affix_id):
			continue
		if not _affix_matches_base(affix, base):
			continue
		var weight: int = int(affix.get("weight", 1))
		candidates.append(affix)
		total_weight += weight
	if candidates.is_empty() or total_weight <= 0:
		return {}
	var roll: int = rng.randi_range(1, total_weight)
	var cursor: int = 0
	for candidate: Dictionary in candidates:
		cursor += int(candidate.get("weight", 1))
		if roll <= cursor:
			return _scale_affix(candidate, item_level, rng)
	return _scale_affix(candidates.back(), item_level, rng)

static func _affix_matches_base(affix: Dictionary, base: Dictionary) -> bool:
	var base_tags: Array = base.get("affix_tags", [])
	var affix_tags: Array = affix.get("tags", [])
	for tag_value: Variant in affix_tags:
		if base_tags.has(str(tag_value)):
			return true
	return false

static func _scale_affix(affix: Dictionary, item_level: int, rng: RandomNumberGenerator) -> Dictionary:
	var result: Dictionary = affix.duplicate(true)
	var tier: int = clamp(1 + int(item_level / 12) + rng.randi_range(0, 1), 1, 6)
	result["tier"] = tier
	var scaled_stats: Dictionary = {}
	var stats: Dictionary = affix.get("stats", {})
	for stat_name: Variant in stats.keys():
		var base_value: float = float(stats[stat_name])
		var variance: float = rng.randf_range(0.85, 1.18)
		var scaled: float = base_value * float(tier) * variance
		scaled_stats[str(stat_name)] = scaled
	result["stats"] = scaled_stats
	return result

static func merge_stats(target: Dictionary, addition: Dictionary) -> void:
	for key: Variant in addition.keys():
		var stat_name: String = str(key)
		target[stat_name] = float(target.get(stat_name, 0.0)) + float(addition[key])

static func flatten_affix_names(prefixes: Array, suffixes: Array) -> Array[String]:
	var names: Array[String] = []
	for prefix_value: Variant in prefixes:
		if typeof(prefix_value) == TYPE_DICTIONARY:
			var p: Dictionary = prefix_value
			names.append(str(p.get("name", "Prefix")))
	for suffix_value: Variant in suffixes:
		if typeof(suffix_value) == TYPE_DICTIONARY:
			var s: Dictionary = suffix_value
			names.append(str(s.get("name", "Suffix")))
	return names

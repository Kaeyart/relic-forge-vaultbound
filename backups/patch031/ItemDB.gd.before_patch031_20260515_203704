const MAGIC_PREFIX_NAMES: Array[String] = ["Ashen", "Rift", "Storm", "Grave", "Iron", "Gilded", "Frost", "Hollow", "Tempered", "Vigilant"]
const MAGIC_SUFFIX_NAMES: Array[String] = ["of Embers", "of the Vault", "of Breaking", "of Focus", "of Teeth", "of Warding", "of Reach", "of Ash", "of Hunger", "of Echoes"]
const RARE_FIRST_NAMES: Array[String] = ["Dread", "Grave", "Ash", "Storm", "Frost", "Iron", "Rift", "Blood", "Vault", "Night"]
const RARE_SECOND_NAMES: Array[String] = ["brand", "song", "breaker", "grip", "ward", "fang", "pulse", "mantle", "chain", "veil"]

static func make_starter_weapon() -> Dictionary:
	var base: Dictionary = _base_by_id("ember_wand")
	var item: Dictionary = _make_base_item(base, RARITY_NORMAL, 1, null)
	item["name"] = "Starter Wand"
	item["description"] = "A basic spell focus. Replace it as soon as a real drop appears."
	return item

static func generate_drop(state: RVGameState, depth: int) -> Dictionary:
	var item_level: int = max(1, int(state.level) + max(0, depth - 1))
	if state.rng.randf() < _unique_chance(depth):
		var unique_item: Dictionary = _roll_unique(state, item_level)
		if not unique_item.is_empty():
			return unique_item
	var base: Dictionary = BASES[state.rng.randi_range(0, BASES.size() - 1)]
	var rarity: String = _roll_rarity(state, depth)
	return _make_base_item(base, rarity, item_level, state.rng)

static func craft_basic_item(state: RVGameState) -> Dictionary:
	var base: Dictionary = _base_by_id("relic_core")
	var item: Dictionary = _make_base_item(base, RARITY_MAGIC, max(1, state.level), state.rng)
	item["rarity"] = "Crafted"
	item["name"] = "Crafted " + str(base.get("name", "Relic"))
	item["forge_potential"] = int(item.get("forge_potential", 0)) + 8
	return item

static func _roll_rarity(state: RVGameState, depth: int) -> String:
	var roll: float = state.rng.randf()
	var rare_bonus: float = min(0.12, float(depth) * 0.01)
	if roll < 0.18:
		return RARITY_NORMAL
	if roll < 0.70 - rare_bonus:
		return RARITY_MAGIC
	return RARITY_RARE

static func _unique_chance(depth: int) -> float:
	return clamp(0.025 + float(depth) * 0.006, 0.025, 0.09)

static func _roll_unique(state: RVGameState, item_level: int) -> Dictionary:
	var candidates: Array[Dictionary] = []
	for unique_data: Dictionary in UNIQUE_ITEMS:
		if int(unique_data.get("required_level", 1)) <= item_level:
			candidates.append(unique_data)
	if candidates.is_empty():
		return {}
	var chosen: Dictionary = candidates[state.rng.randi_range(0, candidates.size() - 1)]
	return _make_unique_item(chosen, item_level, state.rng)

static func _make_unique_item(unique_data: Dictionary, item_level: int, rng: RandomNumberGenerator) -> Dictionary:
	var base: Dictionary = _base_by_id(str(unique_data.get("base_id", "relic_core")))
	var item: Dictionary = _make_base_shell(base, RARITY_UNIQUE, item_level)
	item["name"] = str(unique_data.get("name", "Unique Item"))
	item["unique_id"] = str(unique_data.get("id", "unique"))
	item["required_level"] = int(unique_data.get("required_level", 1))
	item["description"] = str(unique_data.get("description", "A build-defining unique item."))
	item["unique_lines"] = unique_data.get("unique_lines", [])
	item["flags"] = unique_data.get("flags", [])
	item["unique_stats"] = _scale_unique_stats(unique_data.get("unique_stats", {}), item_level, rng)
	_rebuild_item_stats(item)
	item["forge_potential"] = 0
	return item

static func _make_base_item(base: Dictionary, rarity: String, item_level: int, rng: RandomNumberGenerator) -> Dictionary:
	var item: Dictionary = _make_base_shell(base, rarity, item_level)
	if rarity != RARITY_NORMAL and rng != null:
		var affix_result: Dictionary = RVItemAffixDB.generate_affixes(base, rarity, item_level, rng)
		item["prefixes"] = affix_result.get("prefixes", [])
		item["suffixes"] = affix_result.get("suffixes", [])
	item["name"] = _generate_item_name(item, rng)
	item["forge_potential"] = _forge_potential_for(item, rng)
	_rebuild_item_stats(item)
	return item

static func _make_base_shell(base: Dictionary, rarity: String, item_level: int) -> Dictionary:
	return {
		"name": str(base.get("name", "Item")),
		"base_name": str(base.get("name", "Item")),
		"base_id": str(base.get("id", "base")),
		"base_type": str(base.get("base_type", "Item")),
		"slot": str(base.get("slot", "relic")),
		"rarity": rarity,
		"item_level": item_level,
		"armor_class": str(base.get("armor_class", "")),
		"description": str(base.get("description", "")),
		"item_tags": base.get("item_tags", []),
		"implicit_stats": base.get("implicit_stats", {}).duplicate(true),
		"prefixes": [],
		"suffixes": [],
		"unique_stats": {},
		"unique_lines": [],
		"flags": [],
		"stats": {},
		"affixes": []
	}

static func _generate_item_name(item: Dictionary, rng: RandomNumberGenerator) -> String:
	var rarity: String = str(item.get("rarity", RARITY_NORMAL))
	var base_name: String = str(item.get("base_name", "Item"))
	match rarity:
		RARITY_NORMAL:
			return base_name
		RARITY_MAGIC:
			var first: String = MAGIC_PREFIX_NAMES[0]
			var second: String = MAGIC_SUFFIX_NAMES[0]
			if rng != null:
				first = MAGIC_PREFIX_NAMES[rng.randi_range(0, MAGIC_PREFIX_NAMES.size() - 1)]
				second = MAGIC_SUFFIX_NAMES[rng.randi_range(0, MAGIC_SUFFIX_NAMES.size() - 1)]
			return first + " " + base_name + " " + second
		RARITY_RARE:
			var rare_first: String = RARE_FIRST_NAMES[0]
			var rare_second: String = RARE_SECOND_NAMES[0]
			if rng != null:
				rare_first = RARE_FIRST_NAMES[rng.randi_range(0, RARE_FIRST_NAMES.size() - 1)]
				rare_second = RARE_SECOND_NAMES[rng.randi_range(0, RARE_SECOND_NAMES.size() - 1)]
			return rare_first + rare_second.capitalize() + " " + base_name
		_:
			return base_name

static func _forge_potential_for(item: Dictionary, rng: RandomNumberGenerator) -> int:
	var level: int = int(item.get("item_level", 1))
	var rarity: String = str(item.get("rarity", RARITY_NORMAL))
	var base: int = 8 + int(level / 2)
	match rarity:
		RARITY_NORMAL:
			base += 8
		RARITY_MAGIC:
			base += 5
		RARITY_RARE:
			base += 1
		RARITY_UNIQUE:
			return 0
	if rng != null:
		base += rng.randi_range(-2, 5)
	return max(1, base)

static func _scale_unique_stats(stats: Dictionary, item_level: int, rng: RandomNumberGenerator) -> Dictionary:
	var result: Dictionary = {}
	for key: Variant in stats.keys():
		var value: float = float(stats[key])
		var variance: float = 1.0
		if rng != null:
			variance = rng.randf_range(0.90, 1.12)
		var level_bonus: float = 1.0 + min(0.35, float(item_level) * 0.006)
		result[str(key)] = value * variance * level_bonus
	return result

static func _rebuild_item_stats(item: Dictionary) -> void:
	var total: Dictionary = {}
	RVItemAffixDB.merge_stats(total, item.get("implicit_stats", {}))
	for prefix_value: Variant in item.get("prefixes", []):
		if typeof(prefix_value) == TYPE_DICTIONARY:
			RVItemAffixDB.merge_stats(total, prefix_value.get("stats", {}))
	for suffix_value: Variant in item.get("suffixes", []):
		if typeof(suffix_value) == TYPE_DICTIONARY:
			RVItemAffixDB.merge_stats(total, suffix_value.get("stats", {}))
	RVItemAffixDB.merge_stats(total, item.get("unique_stats", {}))
	item["stats"] = total
	item["affixes"] = RVItemAffixDB.flatten_affix_names(item.get("prefixes", []), item.get("suffixes", []))

static func _base_by_id(base_id: String) -> Dictionary:
	for base: Dictionary in BASES:
		if str(base.get("id", "")) == base_id:
			return base.duplicate(true)
	return BASES[0].duplicate(true)

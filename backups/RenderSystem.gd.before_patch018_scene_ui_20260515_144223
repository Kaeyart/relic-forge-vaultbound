class_name RVRenderSystem
extends RefCounted

static func draw_world(node: Node2D, state: RVGameState, textures: Dictionary = {}) -> void:
	if state.mode == "hub": draw_hub(node, state, textures)
	else: draw_combat(node, state, textures)
	draw_entities(node, state, textures)
	draw_hud(node, state, textures)
	if state.panel_mode == "passive_tree": draw_passive_panel(node, state, textures)
	elif state.panel_mode == "skill_gems": draw_skill_panel(node, state, textures)
	elif state.panel_mode == "crafting": draw_crafting_panel(node, state, textures)

static func draw_hub(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	var rect: Rect2 = state.hub_bounds.grow(25.0)
	node.draw_rect(rect, Color(0.014, 0.013, 0.016, 0.96), true)
	node.draw_rect(rect, Color(0.70, 0.54, 0.30, 0.24), false, 2.0)
	var c: Vector2 = Vector2(640.0, 370.0)
	node.draw_arc(c, 265.0, -PI, PI, 128, Color(0.85, 0.62, 0.34, 0.10), 2.0)
	node.draw_arc(c, 160.0, -PI, PI, 128, Color(0.85, 0.62, 0.34, 0.14), 2.0)
	draw_label(node, Vector2(615.0, 90.0), "ACTIVITY GATES", Color(0.90, 0.58, 1.0), 12)
	draw_label(node, Vector2(990.0, 185.0), "CRAFTING", Color(1.0, 0.48, 0.18), 12)
	draw_label(node, Vector2(330.0, 185.0), "PASSIVE ATLAS", Color(0.74, 0.62, 1.0), 12)
	draw_label(node, Vector2(650.0, 500.0), "SKILL GEMS", Color(0.56, 1.0, 0.76), 12)
	draw_label(node, Vector2(690.0, 395.0), "STASH / ARMORY", Color(0.95, 0.78, 0.34), 12)
	for obj in state.hub_objects:
		draw_hub_object(node, state, obj)

static func draw_hub_object(node: Node2D, state: RVGameState, obj: Dictionary) -> void:
	var pos: Vector2 = obj.get("pos", Vector2.ZERO)
	var color: Color = obj.get("color", Color(0.90, 0.84, 0.70))
	var kind: String = str(obj.get("type", ""))
	var focused: bool = not state.focused_object.is_empty() and str(state.focused_object.get("name", "")) == str(obj.get("name", "")) and state.player_pos.distance_to(pos) <= 58.0
	var radius: float = 31.0 if focused else 24.0
	node.draw_circle(pos + Vector2(5.0, 8.0), radius + 6.0, Color(0.0, 0.0, 0.0, 0.30))
	if kind == "contract":
		node.draw_arc(pos, radius + 8.0, -PI, PI, 64, Color(color.r, color.g, color.b, 0.70), 4.0)
		node.draw_line(pos + Vector2(-18.0, 18.0), pos + Vector2(0.0, -22.0), color, 3.0)
		node.draw_line(pos + Vector2(18.0, 18.0), pos + Vector2(0.0, -22.0), color, 3.0)
	elif kind == "recipe" or kind == "forgecraft":
		node.draw_rect(Rect2(pos - Vector2(24.0, 13.0), Vector2(48.0, 26.0)), Color(0.035, 0.032, 0.034), true)
		node.draw_rect(Rect2(pos - Vector2(24.0, 13.0), Vector2(48.0, 26.0)), color, false, 3.0)
	elif kind == "passive_atlas" or kind == "skill_gems" or kind == "skill_toggle":
		node.draw_circle(pos, radius, Color(0.030, 0.028, 0.034, 0.96))
		node.draw_arc(pos, radius + 4.0, -PI, PI, 64, color, 3.0)
		if kind == "skill_toggle" and state.active_skills.has(str(obj.get("data", ""))): node.draw_circle(pos, 10.0, color)
	else:
		node.draw_circle(pos, radius, Color(0.030, 0.028, 0.034, 0.96))
		node.draw_arc(pos, radius + 4.0, -PI, PI, 64, color, 3.0)
	draw_label(node, pos + Vector2(0.0, radius + 22.0), str(obj.get("name", "")), color, 10)

static func draw_combat(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	var mode: String = str(state.current_contract.get("mode", "Dungeon Run"))
	var base: Color = Color(0.75, 0.33, 0.16)
	if mode == "Material Hunt": base = Color(0.82, 0.66, 0.28)
	elif mode == "Elite Hunt": base = Color(0.90, 0.50, 0.20)
	elif mode == "Boss Trial": base = Color(1.0, 0.20, 0.12)
	elif mode == "Endless Rift": base = Color(0.58, 0.30, 1.0)
	node.draw_rect(state.arena, Color(base.r * 0.08, base.g * 0.08, base.b * 0.08, 0.98), true)
	node.draw_rect(state.arena, Color(base.r, base.g, base.b, 0.24), false, 2.0)
	var x: float = state.arena.position.x
	while x <= state.arena.end.x:
		node.draw_line(Vector2(x, state.arena.position.y), Vector2(x, state.arena.end.y), Color(base.r, base.g, base.b, 0.045), 1.0)
		x += 72.0
	var y: float = state.arena.position.y
	while y <= state.arena.end.y:
		node.draw_line(Vector2(state.arena.position.x, y), Vector2(state.arena.end.x, y), Color(base.r, base.g, base.b, 0.045), 1.0)
		y += 72.0
	for ob in state.obstacles:
		var pos: Vector2 = ob.get("pos", Vector2.ZERO)
		var radius: float = float(ob.get("radius", 24.0))
		node.draw_circle(pos + Vector2(6.0, 9.0), radius + 3.0, Color(0.0, 0.0, 0.0, 0.32))
		node.draw_circle(pos, radius, Color(0.10, 0.085, 0.075, 0.95))
		node.draw_arc(pos, radius, -PI, PI, 40, Color(0.48, 0.38, 0.28, 0.45), 2.0)

static func draw_entities(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	for z in state.zones:
		var col: Color = color_for_tags(z.get("tags", []))
		var pos: Vector2 = z.get("pos", Vector2.ZERO)
		var r: float = float(z.get("radius", 40.0))
		node.draw_circle(pos, r, Color(col.r, col.g, col.b, 0.10))
		node.draw_arc(pos, r, -PI, PI, 72, Color(col.r, col.g, col.b, 0.52), 3.0)
	for p in state.projectiles:
		var pcol: Color = color_for_tags(p.get("tags", []))
		var ppos: Vector2 = p.get("pos", Vector2.ZERO)
		node.draw_circle(ppos, float(p.get("radius", 6.0)) * 2.0, Color(pcol.r, pcol.g, pcol.b, 0.18))
		node.draw_circle(ppos, float(p.get("radius", 6.0)), pcol)
	for e in state.enemies:
		if float(e.get("hp", 0.0)) <= 0.0: continue
		var epos: Vector2 = e.get("pos", Vector2.ZERO)
		var er: float = float(e.get("radius", 16.0))
		var ecol: Color = e.get("color", Color(0.90, 0.25, 0.15))
		var role: String = str(e.get("role", "chaser"))
		node.draw_circle(epos + Vector2(6.0, 10.0), er * 1.15, Color(0.0, 0.0, 0.0, 0.36))
		if role == "brute" or role == "elite" or role == "boss": draw_hex(node, epos, er * 1.15, Color(0.030, 0.032, 0.038), ecol)
		elif role == "shooter" or role == "spitter" or role == "caster": draw_diamond(node, epos, er * 1.2, Color(0.030, 0.030, 0.037), ecol)
		else:
			node.draw_circle(epos, er, Color(0.030, 0.030, 0.036))
			node.draw_circle(epos, er * 0.70, ecol)
		var pct: float = clamp(float(e.get("hp", 1.0)) / max(1.0, float(e.get("max_hp", 1.0))), 0.0, 1.0)
		node.draw_rect(Rect2(epos + Vector2(-er, -er - 12.0), Vector2(er * 2.0, 4.0)), Color(0.08, 0.04, 0.04, 0.75), true)
		node.draw_rect(Rect2(epos + Vector2(-er, -er - 12.0), Vector2(er * 2.0 * pct, 4.0)), Color(0.90, 0.20, 0.14, 0.85), true)
	draw_player(node, state)
	for ft in state.floating_text:
		draw_label(node, ft.get("pos", Vector2.ZERO), str(ft.get("text", "")), ft.get("color", Color.WHITE), 12)

static func draw_player(node: Node2D, state: RVGameState) -> void:
	var pos: Vector2 = state.player_pos
	var dir: Vector2 = node.get_global_mouse_position() - pos
	if dir.length() < 0.01: dir = Vector2.RIGHT
	else: dir = dir.normalized()
	var side: Vector2 = Vector2(-dir.y, dir.x)
	node.draw_circle(pos + Vector2(6.0, 10.0), 20.0, Color(0.0, 0.0, 0.0, 0.36))
	node.draw_circle(pos, 17.0, Color(0.020, 0.020, 0.024))
	node.draw_circle(pos, 12.0, Color(0.92, 0.84, 0.66))
	node.draw_polygon(PackedVector2Array([pos + dir * 25.0, pos - dir * 9.0 + side * 9.0, pos - dir * 9.0 - side * 9.0]), PackedColorArray([Color(1.0, 0.68, 0.26)]))
	var hp_pct: float = clamp(state.player_hp / max(1.0, state.max_hp), 0.0, 1.0)
	node.draw_arc(pos, 34.0, -PI * 0.5, -PI * 0.5 + TAU * hp_pct, 64, Color(0.80, 1.0, 0.62, 0.55), 3.0)

static func draw_hud(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	var font: Font = ThemeDB.fallback_font
	var top: String = "Lv " + str(state.level) + "  XP " + str(int(state.xp)) + "/" + str(int(state.xp_to_next())) + "  Passive " + str(state.mastery_points) + "  Refund " + str(state.refund_points) + "  Spirit " + str(state.spirit_reserved) + "/" + str(state.spirit_max) + "  Gold " + str(state.gold)
	node.draw_rect(Rect2(Vector2(14.0, 14.0), Vector2(1250.0, 30.0)), Color(0.018, 0.017, 0.020, 0.82), true)
	node.draw_string(font, Vector2(28.0, 35.0), top, HORIZONTAL_ALIGNMENT_LEFT, -1, 13, Color(0.88, 0.84, 0.74))
	draw_bar(node, textures, "ui_health_bar_frame", Vector2(18.0, 610.0), state.player_hp / max(1.0, state.max_hp), Color(0.90, 0.18, 0.12))
	draw_bar(node, textures, "ui_mana_bar_frame", Vector2(18.0, 645.0), state.player_mana / max(1.0, state.max_mana), Color(0.25, 0.68, 1.0))
	var start_x: float = 440.0
	for i in range(6):
		var pos: Vector2 = Vector2(start_x + float(i) * 62.0, 620.0)
		var selected: bool = i == state.selected_skill
		var tex_key: String = "ui_skill_slot_selected" if selected else "ui_skill_slot_empty"
		if textures.has(tex_key): node.draw_texture_rect(textures[tex_key], Rect2(pos, Vector2(54.0, 54.0)), false, Color.WHITE)
		else:
			node.draw_rect(Rect2(pos, Vector2(52.0, 52.0)), Color(0.030, 0.030, 0.036), true)
			node.draw_rect(Rect2(pos, Vector2(52.0, 52.0)), Color(1.0, 0.76, 0.35) if selected else Color(0.35, 0.32, 0.28), false, 2.0)
		if i < state.active_skills.size():
			var skill: String = str(state.active_skills[i])
			var col: Color = RVSkillDB.color(skill)
			node.draw_circle(pos + Vector2(27.0, 25.0), 13.0, Color(col.r, col.g, col.b, 0.85))
			node.draw_string(font, pos + Vector2(4.0, 50.0), str(i + 1), HORIZONTAL_ALIGNMENT_LEFT, -1, 10, Color(0.94, 0.86, 0.68))
	if state.prompt != "": draw_chip(node, textures, Vector2(315.0, 675.0), Vector2(650.0, 28.0), state.prompt, 13)
	if state.notice_time > 0.0: draw_chip(node, textures, Vector2(420.0, 52.0), Vector2(520.0, 32.0), state.notice, 14)

static func draw_bar(node: Node2D, textures: Dictionary, key: String, pos: Vector2, pct: float, fill: Color) -> void:
	if textures.has(key): node.draw_texture_rect(textures[key], Rect2(pos, Vector2(256.0, 32.0)), false, Color.WHITE)
	else: node.draw_rect(Rect2(pos, Vector2(256.0, 32.0)), Color(0.018, 0.017, 0.020, 0.82), true)
	var inner: Rect2 = Rect2(pos + Vector2(24.0, 11.0), Vector2(208.0 * clamp(pct, 0.0, 1.0), 8.0))
	node.draw_rect(inner, fill, true)

static func draw_chip(node: Node2D, textures: Dictionary, pos: Vector2, size: Vector2, text: String, font_size: int) -> void:
	if textures.has("ui_notice_banner"): node.draw_texture_rect(textures["ui_notice_banner"], Rect2(pos, size), false, Color.WHITE)
	else: node.draw_rect(Rect2(pos, size), Color(0.018, 0.017, 0.020, 0.84), true)
	node.draw_string(ThemeDB.fallback_font, pos + Vector2(18.0, size.y * 0.70), text, HORIZONTAL_ALIGNMENT_LEFT, -1, font_size, Color(0.96, 0.88, 0.68))

static func draw_passive_panel(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	draw_panel(node, textures, "Passive Atlas", "Q/E select · Enter allocate · Backspace refund · Esc close")
	var nodes: Dictionary = RVBuildcraftSystem.passive_nodes()
	var selected: String = RVBuildcraftSystem.selected_passive_id(state)
	var origin: Vector2 = Vector2(640.0, 375.0)
	for id in nodes.keys():
		var n: Dictionary = nodes[id]
		var p: Vector2 = origin + n.get("pos", Vector2.ZERO) * 0.58
		for link in n.get("links", []):
			if nodes.has(str(link)):
				node.draw_line(p, origin + nodes[str(link)].get("pos", Vector2.ZERO) * 0.58, Color(0.35, 0.32, 0.28, 0.55), 1.0)
	for id2 in nodes.keys():
		var n2: Dictionary = nodes[id2]
		var p2: Vector2 = origin + n2.get("pos", Vector2.ZERO) * 0.58
		var allocated: bool = state.passive_atlas_allocated.has(str(id2))
		var is_selected: bool = str(id2) == selected
		var col: Color = branch_color(str(n2.get("branch", "core")))
		var r: float = 8.0
		if str(n2.get("kind", "small")) == "notable": r = 12.0
		elif str(n2.get("kind", "small")) == "keystone": r = 16.0
		node.draw_circle(p2, r + 3.0, Color(col.r, col.g, col.b, 0.18 if allocated else 0.08))
		node.draw_circle(p2, r, col if allocated else Color(0.06, 0.055, 0.06))
		if is_selected: node.draw_arc(p2, r + 7.0, -PI, PI, 40, Color(1.0, 0.86, 0.42), 2.0)
	var sn: Dictionary = nodes.get(selected, {})
	draw_label(node, Vector2(385.0, 565.0), str(sn.get("name", "Node")) + " · Cost " + str(sn.get("cost", 1)), Color(1.0, 0.86, 0.42), 14)

static func draw_skill_panel(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	draw_panel(node, textures, "Skill Gems", "Q/E skill · W/S support · Enter socket · X remove · R spirit · 1-6 loadout")
	var skill: String = RVBuildcraftSystem.selected_gem_skill(state)
	var support: String = RVBuildcraftSystem.selected_support(state)
	draw_label(node, Vector2(390.0, 190.0), "Skill: " + skill, RVSkillDB.color(skill), 18)
	draw_label(node, Vector2(390.0, 230.0), RVSkillDB.description(skill), Color(0.85, 0.82, 0.74), 13)
	draw_label(node, Vector2(390.0, 280.0), "Selected Support: " + support, Color(0.95, 0.80, 0.42), 15)
	draw_label(node, Vector2(390.0, 315.0), str(RVSkillGemDB.support_data(support).get("desc", "")), Color(0.82, 0.78, 0.70), 13)
	var sockets: Array = state.skill_gem_sockets.get(skill, [])
	draw_label(node, Vector2(390.0, 370.0), "Socketed Supports: " + ", ".join(sockets), Color(0.72, 0.90, 1.0), 13)
	draw_label(node, Vector2(390.0, 425.0), "Spirit: " + str(state.spirit_reserved) + "/" + str(state.spirit_max), Color(0.70, 0.36, 1.0), 14)
	draw_label(node, Vector2(390.0, 455.0), "Active Loadout: " + ", ".join(state.active_skills), Color(0.96, 0.88, 0.68), 13)

static func draw_crafting_panel(node: Node2D, state: RVGameState, textures: Dictionary) -> void:
	draw_panel(node, textures, "Crafting", "F craft base · E add/upgrade affix · X reroll · R shatter · W/S item · Esc close")
	if state.backpack.size() == 0:
		draw_label(node, Vector2(390.0, 210.0), "Backpack empty. Press F to craft a blank base item.", Color(0.90, 0.82, 0.68), 15); return
	state.forge_focus_index = clamp(state.forge_focus_index, 0, state.backpack.size() - 1)
	var item: Dictionary = state.backpack[state.forge_focus_index]
	draw_label(node, Vector2(390.0, 190.0), "Focused Item: " + str(item.get("name", "Item")), Color(1.0, 0.86, 0.42), 18)
	draw_label(node, Vector2(390.0, 225.0), "Slot: " + str(item.get("slot", "item")) + " · Rarity: " + str(item.get("rarity", "Magic")) + " · Forge Potential: " + str(item.get("forge_potential", 0)), Color(0.85, 0.82, 0.74), 13)
	var y: float = 270.0
	for k in item.get("stats", {}).keys():
		draw_label(node, Vector2(410.0, y), str(RVItemDB.AFFIXES.get(k, {}).get("name", k)) + ": " + stat_text(float(item["stats"][k])), Color(0.72, 0.90, 1.0), 13)
		y += 26.0
	draw_label(node, Vector2(390.0, 470.0), "Shards: " + str(state.crafting_shards), Color(0.80, 0.76, 0.68), 11)

static func draw_panel(node: Node2D, textures: Dictionary, title: String, help: String) -> void:
	if textures.has("ui_main_window_panel"): node.draw_texture_rect(textures["ui_main_window_panel"], Rect2(Vector2(300.0, 110.0), Vector2(680.0, 500.0)), false, Color.WHITE)
	else: node.draw_rect(Rect2(Vector2(300.0, 110.0), Vector2(680.0, 500.0)), Color(0.018, 0.017, 0.020, 0.94), true)
	draw_label(node, Vector2(390.0, 155.0), title, Color(1.0, 0.86, 0.42), 22)
	draw_label(node, Vector2(390.0, 590.0), help, Color(0.75, 0.70, 0.62), 12)

static func draw_label(node: Node2D, pos: Vector2, text: String, color: Color, size: int = 11) -> void:
	node.draw_string(ThemeDB.fallback_font, pos, text, HORIZONTAL_ALIGNMENT_LEFT, -1, size, color)

static func draw_hex(node: Node2D, pos: Vector2, radius: float, fill: Color, outline: Color) -> void:
	var pts: PackedVector2Array = PackedVector2Array()
	for i in range(6):
		pts.append(pos + Vector2(cos(PI / 6.0 + float(i) * TAU / 6.0), sin(PI / 6.0 + float(i) * TAU / 6.0)) * radius)
	node.draw_polygon(pts, PackedColorArray([fill])); var closed: PackedVector2Array = PackedVector2Array(pts); closed.append(pts[0]); node.draw_polyline(closed, outline, 2.0)

static func draw_diamond(node: Node2D, pos: Vector2, radius: float, fill: Color, outline: Color) -> void:
	var pts: PackedVector2Array = PackedVector2Array([pos + Vector2(0.0, -radius), pos + Vector2(radius, 0.0), pos + Vector2(0.0, radius), pos + Vector2(-radius, 0.0)])
	node.draw_polygon(pts, PackedColorArray([fill])); node.draw_polyline(PackedVector2Array([pts[0], pts[1], pts[2], pts[3], pts[0]]), outline, 2.0)

static func color_for_tags(tags: Array) -> Color:
	if tags.has("Fire"): return Color(1.0, 0.34, 0.10)
	if tags.has("Cold"): return Color(0.42, 0.82, 1.0)
	if tags.has("Lightning"): return Color(0.72, 0.92, 1.0)
	if tags.has("Void"): return Color(0.70, 0.36, 1.0)
	if tags.has("Trap"): return Color(0.95, 0.72, 0.28)
	if tags.has("Physical") or tags.has("Attack"): return Color(1.0, 0.80, 0.48)
	return Color(0.90, 0.84, 0.70)

static func branch_color(branch: String) -> Color:
	if RVPassiveAtlasDB.BRANCH_DATA.has(branch): return RVPassiveAtlasDB.BRANCH_DATA[branch].get("color", Color(0.90, 0.84, 0.70))
	return Color(0.90, 0.84, 0.70)

static func stat_text(value: float) -> String:
	if abs(value) < 1.0: return str(round(value * 1000.0) / 10.0) + "%"
	return str(int(value))

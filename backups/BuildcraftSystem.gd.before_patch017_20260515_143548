class_name RVBuildcraftSystem
extends RefCounted

static func ensure_state(state: RVGameState) -> void:
	if state.passive_atlas_allocated.size() == 0:
		state.passive_atlas_allocated.append("center")
	if state.support_gem_inventory.is_empty():
		for support_id in RVGemDB.support_ids():
			state.support_gem_inventory[support_id] = 2
	if state.spirit_gems_enabled.is_empty():
		for spirit_id in RVGemDB.spirit_ids():
			state.spirit_gems_enabled[spirit_id] = false
	if state.crafting_shards.is_empty():
		state.crafting_shards = RVForgecraftDB.default_crafting_shards()
	if state.glyph_counts.is_empty():
		state.glyph_counts = RVForgecraftDB.default_glyphs()
	if state.rune_counts.is_empty():
		state.rune_counts = RVForgecraftDB.default_runes()
	for skill in RVSkillDB.names():
		if not state.skill_gem_sockets.has(skill):
			state.skill_gem_sockets[skill] = []
	rebuild_build_stats(state)

static func update(state: RVGameState, delta: float) -> void:
	ensure_state(state)

static func append_hub_objects(state: RVGameState) -> void:
	var existing_types: Array = []
	for obj in state.hub_objects:
		existing_types.append(str(obj.get("type", "")))
	if not existing_types.has("passive_atlas_station"):
		state.hub_objects.append({"type":"passive_atlas_station","name":"Passive Atlas","pos":Vector2(505.0,360.0),"color":Color(0.92,0.68,0.34),"data":{},"prompt":"E open Passive Atlas · P"})
	if not existing_types.has("gem_board_station"):
		state.hub_objects.append({"type":"gem_board_station","name":"Gem Board","pos":Vector2(570.0,360.0),"color":Color(0.54,0.80,1.0),"data":{},"prompt":"E open Skill Gems · K"})
	if not existing_types.has("forgecraft_station"):
		state.hub_objects.append({"type":"forgecraft_station","name":"Forgecraft","pos":Vector2(760.0,360.0),"color":Color(1.0,0.44,0.18),"data":{},"prompt":"E open Forgecraft · C"})

static func try_interact(state: RVGameState) -> bool:
	if state.focused_object.is_empty():
		return false
	var t: String = str(state.focused_object.get("type", ""))
	if t == "passive_atlas_station":
		open_panel(state, "passive")
		return true
	if t == "gem_board_station":
		open_panel(state, "gems")
		return true
	if t == "forgecraft_station":
		open_panel(state, "forge")
		return true
	return false

static func open_panel(state: RVGameState, panel: String) -> void:
	ensure_state(state)
	state.buildcraft_panel = panel
	state.add_notice(panel.capitalize() + " opened")

static func close_panel(state: RVGameState) -> void:
	state.buildcraft_panel = ""
	state.add_notice("Closed")

static func handle_key(state: RVGameState, keycode: int) -> bool:
	ensure_state(state)
	if keycode == KEY_P:
		open_panel(state, "passive")
		return true
	if keycode == KEY_K:
		open_panel(state, "gems")
		return true
	if keycode == KEY_C:
		open_panel(state, "forge")
		return true
	if state.buildcraft_panel == "":
		return false
	if keycode == KEY_ESCAPE:
		close_panel(state)
		return true
	if state.buildcraft_panel == "passive":
		return handle_passive_key(state, keycode)
	if state.buildcraft_panel == "gems":
		return handle_gem_key(state, keycode)
	if state.buildcraft_panel == "forge":
		return handle_forge_key(state, keycode)
	return false

static func handle_passive_key(state: RVGameState, keycode: int) -> bool:
	var node_ids: Array = RVPassiveAtlasDB.nodes().keys()
	node_ids.sort()
	if keycode == KEY_Q:
		state.passive_atlas_cursor = wrapi(state.passive_atlas_cursor - 1, 0, node_ids.size())
		return true
	if keycode == KEY_E:
		state.passive_atlas_cursor = wrapi(state.passive_atlas_cursor + 1, 0, node_ids.size())
		return true
	if keycode == KEY_ENTER or keycode == KEY_KP_ENTER:
		var node_id: String = str(node_ids[state.passive_atlas_cursor])
		allocate_node(state, node_id)
		return true
	if keycode == KEY_BACKSPACE:
		refund_last_node(state)
		return true
	return true

static func allocate_node(state: RVGameState, node_id: String) -> void:
	var all_nodes: Dictionary = RVPassiveAtlasDB.nodes()
	if not all_nodes.has(node_id):
		return
	var node: Dictionary = all_nodes[node_id]
	var cost: int = int(node.get("cost", 1))
	if state.passive_atlas_allocated.has(node_id):
		state.add_notice("Already allocated")
		return
	if not RVPassiveAtlasDB.can_allocate(state.passive_atlas_allocated, node_id):
		state.add_notice("Node is not connected")
		return
	if state.mastery_points < cost:
		state.add_notice("Need " + str(cost) + " mastery")
		return
	state.mastery_points -= cost
	state.passive_atlas_allocated.append(node_id)
	state.passive_atlas_refund_stack.append(node_id)
	rebuild_build_stats(state)
	state.recompute_stats()
	state.add_notice("Allocated " + str(node["name"]))

static func refund_last_node(state: RVGameState) -> void:
	if state.passive_atlas_refund_stack.size() == 0:
		state.add_notice("Nothing to refund")
		return
	var node_id: String = str(state.passive_atlas_refund_stack.pop_back())
	if node_id == "center":
		return
	var all_nodes: Dictionary = RVPassiveAtlasDB.nodes()
	var cost: int = int(all_nodes.get(node_id, {}).get("cost", 1))
	state.passive_atlas_allocated.erase(node_id)
	state.mastery_points += cost
	rebuild_build_stats(state)
	state.recompute_stats()
	state.add_notice("Refunded " + node_id)

static func handle_gem_key(state: RVGameState, keycode: int) -> bool:
	var skills: Array = RVSkillDB.names()
	if keycode == KEY_Q:
		state.gem_board_skill_cursor = wrapi(state.gem_board_skill_cursor - 1, 0, skills.size())
		return true
	if keycode == KEY_E:
		state.gem_board_skill_cursor = wrapi(state.gem_board_skill_cursor + 1, 0, skills.size())
		return true
	var support_ids: Array = RVGemDB.support_ids()
	if keycode == KEY_W:
		state.gem_board_support_cursor = wrapi(state.gem_board_support_cursor - 1, 0, support_ids.size())
		return true
	if keycode == KEY_S:
		state.gem_board_support_cursor = wrapi(state.gem_board_support_cursor + 1, 0, support_ids.size())
		return true
	if keycode == KEY_ENTER or keycode == KEY_KP_ENTER:
		var skill: String = str(skills[state.gem_board_skill_cursor])
		var support_id: String = str(support_ids[state.gem_board_support_cursor])
		socket_support(state, skill, support_id)
		return true
	if keycode == KEY_BACKSPACE or keycode == KEY_X:
		var skill_remove: String = str(skills[state.gem_board_skill_cursor])
		remove_last_support(state, skill_remove)
		return true
	if keycode >= KEY_1 and keycode <= KEY_6:
		var idx: int = keycode - KEY_1
		if idx < skills.size():
			toggle_skill_loadout(state, str(skills[idx]))
		return true
	if keycode == KEY_R:
		cycle_spirit_gem(state)
		return true
	return true

static func socket_support(state: RVGameState, skill: String, support_id: String) -> void:
	if not RVGemDB.support_compatible(skill, support_id):
		state.add_notice("Support does not fit " + skill)
		return
	if int(state.support_gem_inventory.get(support_id, 0)) <= 0:
		state.add_notice("No support gem copies")
		return
	var sockets: Array = state.skill_gem_sockets.get(skill, [])
	var max_sockets: int = RVGemDB.socket_count_for_skill(skill, int(state.skill_ranks.get(skill, 0)))
	if sockets.size() >= max_sockets:
		state.add_notice("No open support socket")
		return
	sockets.append(support_id)
	state.skill_gem_sockets[skill] = sockets
	state.support_gem_inventory[support_id] = int(state.support_gem_inventory.get(support_id, 0)) - 1
	state.add_notice("Socketed " + str(RVGemDB.SUPPORT_GEMS[support_id]["name"]) + " into " + skill)

static func remove_last_support(state: RVGameState, skill: String) -> void:
	var sockets: Array = state.skill_gem_sockets.get(skill, [])
	if sockets.size() == 0:
		state.add_notice("No support to remove")
		return
	var support_id: String = str(sockets.pop_back())
	state.skill_gem_sockets[skill] = sockets
	state.support_gem_inventory[support_id] = int(state.support_gem_inventory.get(support_id, 0)) + 1
	state.add_notice("Removed support")

static func toggle_skill_loadout(state: RVGameState, skill: String) -> void:
	if state.active_skills.has(skill):
		state.active_skills.erase(skill)
		state.add_notice(skill + " removed")
	else:
		if state.active_skills.size() >= 6:
			state.add_notice("Loadout full")
			return
		state.active_skills.append(skill)
		state.add_notice(skill + " added")
	if state.active_skills.size() == 0:
		state.active_skills.append("Fireball")
	state.selected_skill = clamp(state.selected_skill, 0, state.active_skills.size() - 1)

static func cycle_spirit_gem(state: RVGameState) -> void:
	var ids: Array = RVGemDB.spirit_ids()
	if ids.size() == 0:
		return
	state.spirit_cursor = wrapi(state.spirit_cursor + 1, 0, ids.size())
	var spirit_id: String = str(ids[state.spirit_cursor])
	var enabled: bool = bool(state.spirit_gems_enabled.get(spirit_id, false))
	if enabled:
		state.spirit_gems_enabled[spirit_id] = false
		state.add_notice("Disabled " + str(RVGemDB.SPIRIT_GEMS[spirit_id]["name"]))
	else:
		var reservation: int = int(RVGemDB.SPIRIT_GEMS[spirit_id].get("reservation", 0))
		if spirit_reserved(state) + reservation > state.spirit_max:
			state.add_notice("Not enough spirit")
			return
		state.spirit_gems_enabled[spirit_id] = true
		state.add_notice("Enabled " + str(RVGemDB.SPIRIT_GEMS[spirit_id]["name"]))
	rebuild_build_stats(state)
	state.recompute_stats()

static func handle_forge_key(state: RVGameState, keycode: int) -> bool:
	if keycode == KEY_W:
		state.forge_focus_index = max(0, state.forge_focus_index - 1)
		return true
	if keycode == KEY_S:
		state.forge_focus_index = min(max(0, state.backpack.size() - 1), state.forge_focus_index + 1)
		return true
	if keycode == KEY_F:
		state.backpack.append(RVForgecraftDB.make_base(state))
		state.forge_focus_index = state.backpack.size() - 1
		state.add_notice("Created forge base")
		return true
	if keycode == KEY_E:
		forge_add_or_upgrade(state)
		return true
	if keycode == KEY_X:
		forge_chaos(state)
		return true
	if keycode == KEY_Q:
		forge_seal(state)
		return true
	if keycode == KEY_R:
		forge_shatter(state)
		return true
	if keycode == KEY_T:
		forge_refine(state)
		return true
	return true

static func focused_item(state: RVGameState) -> Dictionary:
	if state.backpack.size() == 0:
		return {}
	state.forge_focus_index = clamp(state.forge_focus_index, 0, state.backpack.size() - 1)
	var item: Variant = state.backpack[state.forge_focus_index]
	if typeof(item) != TYPE_DICTIONARY:
		return {}
	return item

static func write_focused_item(state: RVGameState, item: Dictionary) -> void:
	if state.backpack.size() == 0:
		return
	state.forge_focus_index = clamp(state.forge_focus_index, 0, state.backpack.size() - 1)
	state.backpack[state.forge_focus_index] = item

static func forge_add_or_upgrade(state: RVGameState) -> void:
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		state.add_notice("No backpack item. Press F to make a base.")
		return
	if int(item.get("forging_potential", 0)) <= 0:
		state.add_notice("No forging potential")
		return
	var affix_id: String = choose_affix_for_item(state, item)
	if affix_id == "":
		state.add_notice("No usable affix")
		return
	if int(state.crafting_shards.get(affix_id, 0)) <= 0:
		state.add_notice("Need shard: " + affix_id)
		return
	var affixes: Array = item.get("affixes", [])
	var upgraded: bool = false
	for i in range(affixes.size()):
		var a: Dictionary = affixes[i]
		if str(a.get("id", "")) == affix_id:
			if int(a.get("tier", 1)) >= 5:
				state.add_notice("Affix already T5")
				return
			a["tier"] = int(a.get("tier", 1)) + 1
			affixes[i] = a
			upgraded = true
			break
	if not upgraded:
		if affixes.size() >= 4:
			state.add_notice("No open affix slot")
			return
		affixes.append({"id":affix_id,"tier":1,"sealed":false})
	item["affixes"] = affixes
	state.crafting_shards[affix_id] = int(state.crafting_shards.get(affix_id, 0)) - 1
	consume_forging_potential(state, item, 2, 7)
	item = RVForgecraftDB.rebuild_item_stats(item)
	item["rarity"] = "Crafted"
	write_focused_item(state, item)
	state.recompute_stats()
	state.add_notice("Forged " + affix_id)

static func forge_chaos(state: RVGameState) -> void:
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		return
	if int(state.glyph_counts.get("chaos", 0)) <= 0:
		state.add_notice("Need Glyph of Chaos")
		return
	var affixes: Array = item.get("affixes", [])
	if affixes.size() == 0:
		state.add_notice("No affix to reroll")
		return
	var idx: int = state.rng.randi_range(0, affixes.size() - 1)
	var old: Dictionary = affixes[idx]
	var new_id: String = random_affix_id(state)
	old["id"] = new_id
	affixes[idx] = old
	item["affixes"] = affixes
	state.glyph_counts["chaos"] = int(state.glyph_counts.get("chaos", 0)) - 1
	consume_forging_potential(state, item, 4, 10)
	item = RVForgecraftDB.rebuild_item_stats(item)
	write_focused_item(state, item)
	state.add_notice("Chaos rerolled affix")

static func forge_refine(state: RVGameState) -> void:
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		return
	if int(state.rune_counts.get("refinement", 0)) <= 0:
		state.add_notice("Need Rune of Refinement")
		return
	state.rune_counts["refinement"] = int(state.rune_counts.get("refinement", 0)) - 1
	consume_forging_potential(state, item, 2, 6)
	write_focused_item(state, item)
	state.add_notice("Refined values")

static func forge_seal(state: RVGameState) -> void:
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		return
	if int(state.glyph_counts.get("despair", 0)) <= 0:
		state.add_notice("Need Glyph of Despair")
		return
	if typeof(item.get("sealed_affix", {})) == TYPE_DICTIONARY and not item.get("sealed_affix", {}).is_empty():
		state.add_notice("Already has sealed affix")
		return
	var affixes: Array = item.get("affixes", [])
	if affixes.size() == 0:
		state.add_notice("No affix to seal")
		return
	var a: Dictionary = affixes.pop_back()
	item["affixes"] = affixes
	item["sealed_affix"] = a
	state.glyph_counts["despair"] = int(state.glyph_counts.get("despair", 0)) - 1
	consume_forging_potential(state, item, 5, 12)
	item = RVForgecraftDB.rebuild_item_stats(item)
	write_focused_item(state, item)
	state.add_notice("Sealed affix")

static func forge_shatter(state: RVGameState) -> void:
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		return
	if int(state.rune_counts.get("shattering", 0)) <= 0:
		state.add_notice("Need Rune of Shattering")
		return
	for affix in item.get("affixes", []):
		if typeof(affix) == TYPE_DICTIONARY:
			var id: String = str(affix.get("id", ""))
			state.crafting_shards[id] = int(state.crafting_shards.get(id, 0)) + max(1, int(affix.get("tier", 1)))
	state.rune_counts["shattering"] = int(state.rune_counts.get("shattering", 0)) - 1
	state.backpack.remove_at(state.forge_focus_index)
	state.forge_focus_index = clamp(state.forge_focus_index, 0, max(0, state.backpack.size() - 1))
	state.add_notice("Item shattered into shards")

static func choose_affix_for_item(state: RVGameState, item: Dictionary) -> String:
	var ids: Array = RVForgecraftDB.all_affixes().keys()
	ids.sort()
	if ids.size() == 0:
		return ""
	state.forge_affix_cursor = wrapi(state.forge_affix_cursor, 0, ids.size())
	return str(ids[state.forge_affix_cursor])

static func random_affix_id(state: RVGameState) -> String:
	var ids: Array = RVForgecraftDB.all_affixes().keys()
	if ids.size() == 0:
		return "global_damage"
	return str(ids[state.rng.randi_range(0, ids.size() - 1)])

static func consume_forging_potential(state: RVGameState, item: Dictionary, min_cost: int, max_cost: int) -> void:
	var cost: int = state.rng.randi_range(min_cost, max_cost)
	if int(state.glyph_counts.get("hope", 0)) > 0 and state.rng.randf() < 0.25:
		state.glyph_counts["hope"] = int(state.glyph_counts.get("hope", 0)) - 1
		cost = 0
	item["forging_potential"] = max(0, int(item.get("forging_potential", 0)) - cost)

static func rebuild_build_stats(state: RVGameState) -> void:
	var stats: Dictionary = RVPassiveAtlasDB.aggregate_stats(state.passive_atlas_allocated)
	var flags: Array = stats.get("_flags", [])
	stats.erase("_flags")
	for spirit_id in state.spirit_gems_enabled.keys():
		if bool(state.spirit_gems_enabled[spirit_id]) and RVGemDB.SPIRIT_GEMS.has(spirit_id):
			var spirit: Dictionary = RVGemDB.SPIRIT_GEMS[spirit_id]
			for k in spirit.get("stats", {}).keys():
				stats[k] = float(stats.get(k, 0.0)) + float(spirit["stats"][k])
			for f in spirit.get("flags", []):
				if not flags.has(str(f)):
					flags.append(str(f))
	state.build_stats = stats
	state.build_flags = flags
	state.spirit_reserved = spirit_reserved(state)

static func spirit_reserved(state: RVGameState) -> int:
	var total: int = 0
	for spirit_id in state.spirit_gems_enabled.keys():
		if bool(state.spirit_gems_enabled[spirit_id]) and RVGemDB.SPIRIT_GEMS.has(spirit_id):
			total += int(RVGemDB.SPIRIT_GEMS[spirit_id].get("reservation", 0))
	return total

static func support_damage_multiplier(state: RVGameState, skill: String) -> float:
	var multi: float = 1.0
	for support_id in state.skill_gem_sockets.get(skill, []):
		if RVGemDB.SUPPORT_GEMS.has(str(support_id)):
			multi *= float(RVGemDB.SUPPORT_GEMS[str(support_id)].get("damage_multi", 1.0))
	return multi

static func support_cost_multiplier(state: RVGameState, skill: String) -> float:
	var multi: float = 1.0
	for support_id in state.skill_gem_sockets.get(skill, []):
		if RVGemDB.SUPPORT_GEMS.has(str(support_id)):
			multi *= float(RVGemDB.SUPPORT_GEMS[str(support_id)].get("cost_multi", 1.0))
	return multi

static func support_cooldown_multiplier(state: RVGameState, skill: String) -> float:
	var multi: float = 1.0
	for support_id in state.skill_gem_sockets.get(skill, []):
		if RVGemDB.SUPPORT_GEMS.has(str(support_id)):
			multi *= float(RVGemDB.SUPPORT_GEMS[str(support_id)].get("cooldown_multi", 1.0))
	return multi

static func draw_overlay(node: Node2D, state: RVGameState) -> void:
	if state.buildcraft_panel == "":
		return
	var font: Font = ThemeDB.fallback_font
	var rect: Rect2 = Rect2(Vector2(110, 92), Vector2(1060, 520))
	node.draw_rect(rect, Color(0.018, 0.016, 0.020, 0.94), true)
	node.draw_rect(rect, Color(0.86, 0.62, 0.34, 0.45), false, 2.0)
	if state.buildcraft_panel == "passive":
		draw_passive(node, state, font, rect)
	elif state.buildcraft_panel == "gems":
		draw_gems(node, state, font, rect)
	elif state.buildcraft_panel == "forge":
		draw_forge(node, state, font, rect)

static func draw_passive(node: Node2D, state: RVGameState, font: Font, rect: Rect2) -> void:
	var all_nodes: Dictionary = RVPassiveAtlasDB.nodes()
	var ids: Array = all_nodes.keys()
	ids.sort()
	state.passive_atlas_cursor = wrapi(state.passive_atlas_cursor, 0, ids.size())
	var focus_id: String = str(ids[state.passive_atlas_cursor])
	node.draw_string(font, rect.position + Vector2(24, 34), "PASSIVE ATLAS  Q/E node  Enter allocate  Backspace refund  Esc close", HORIZONTAL_ALIGNMENT_LEFT, -1, 16, Color(1.0,0.84,0.55))
	var center: Vector2 = rect.position + Vector2(530, 280)
	for id in ids:
		var n: Dictionary = all_nodes[id]
		var p: Vector2 = center + n["pos"] * 0.52
		for link in n.get("links", []):
			if all_nodes.has(str(link)):
				var lp: Vector2 = center + all_nodes[str(link)]["pos"] * 0.52
				node.draw_line(p, lp, Color(0.33,0.30,0.25,0.55), 1.0)
	for id2 in ids:
		var n2: Dictionary = all_nodes[id2]
		var p2: Vector2 = center + n2["pos"] * 0.52
		var branch: String = str(n2.get("branch", "core"))
		var col: Color = Color(0.72,0.62,0.45)
		if RVPassiveAtlasDB.BRANCH_DATA.has(branch):
			col = RVPassiveAtlasDB.BRANCH_DATA[branch]["color"]
		var r: float = 6.0
		if str(n2.get("kind", "")) == "notable": r = 9.0
		if str(n2.get("kind", "")) == "keystone": r = 13.0
		if state.passive_atlas_allocated.has(str(id2)):
			node.draw_circle(p2, r + 3.0, Color(col.r,col.g,col.b,0.28))
			node.draw_circle(p2, r, col)
		else:
			node.draw_circle(p2, r, Color(0.06,0.055,0.065))
			node.draw_arc(p2, r + 1.0, -PI, PI, 24, Color(col.r,col.g,col.b,0.45), 1.5)
		if str(id2) == focus_id:
			node.draw_arc(p2, r + 7.0, -PI, PI, 32, Color(1.0,0.86,0.40), 2.0)
	var focus: Dictionary = all_nodes[focus_id]
	node.draw_string(font, rect.position + Vector2(24, 490), str(focus["name"]) + "  cost " + str(focus.get("cost",1)) + "  mastery " + str(state.mastery_points), HORIZONTAL_ALIGNMENT_LEFT, -1, 15, Color(0.92,0.86,0.72))

static func draw_gems(node: Node2D, state: RVGameState, font: Font, rect: Rect2) -> void:
	var skills: Array = RVSkillDB.names()
	var supports: Array = RVGemDB.support_ids()
	state.gem_board_skill_cursor = wrapi(state.gem_board_skill_cursor, 0, skills.size())
	state.gem_board_support_cursor = wrapi(state.gem_board_support_cursor, 0, supports.size())
	var skill: String = str(skills[state.gem_board_skill_cursor])
	var support_id: String = str(supports[state.gem_board_support_cursor])
	node.draw_string(font, rect.position + Vector2(24,34), "SKILL GEM BOARD  Q/E skill  W/S support  Enter socket  X remove  R spirit  1-6 loadout", HORIZONTAL_ALIGNMENT_LEFT, -1, 16, Color(0.62,0.84,1.0))
	node.draw_string(font, rect.position + Vector2(24,76), "Skill: " + skill + "  Sockets " + str(state.skill_gem_sockets.get(skill, []).size()) + "/" + str(RVGemDB.socket_count_for_skill(skill, int(state.skill_ranks.get(skill,0)))), HORIZONTAL_ALIGNMENT_LEFT, -1, 18, RVSkillDB.color(skill))
	var y: float = 118
	for s in skills:
		var prefix: String = "  "
		if str(s) == skill: prefix = "> "
		node.draw_string(font, rect.position + Vector2(42,y), prefix + str(s) + "  supports: " + ", ".join(state.skill_gem_sockets.get(str(s), [])), HORIZONTAL_ALIGNMENT_LEFT, -1, 13, Color(0.88,0.84,0.74))
		y += 26
	node.draw_string(font, rect.position + Vector2(560,76), "Support focus: " + str(RVGemDB.SUPPORT_GEMS[support_id]["name"]) + " x" + str(state.support_gem_inventory.get(support_id,0)), HORIZONTAL_ALIGNMENT_LEFT, -1, 15, Color(1.0,0.86,0.55))
	node.draw_string(font, rect.position + Vector2(560,110), str(RVGemDB.SUPPORT_GEMS[support_id]["desc"]), HORIZONTAL_ALIGNMENT_LEFT, -1, 13, Color(0.86,0.80,0.68))
	node.draw_string(font, rect.position + Vector2(560,160), "Spirit: " + str(state.spirit_reserved) + "/" + str(state.spirit_max), HORIZONTAL_ALIGNMENT_LEFT, -1, 16, Color(0.75,0.92,1.0))
	var sy: float = 196
	for spirit_id in RVGemDB.spirit_ids():
		var on: String = "off"
		if bool(state.spirit_gems_enabled.get(spirit_id,false)): on = "ON"
		node.draw_string(font, rect.position + Vector2(560,sy), str(RVGemDB.SPIRIT_GEMS[spirit_id]["name"]) + "  " + on + "  res " + str(RVGemDB.SPIRIT_GEMS[spirit_id]["reservation"]), HORIZONTAL_ALIGNMENT_LEFT, -1, 13, Color(0.88,0.84,0.74))
		sy += 24

static func draw_forge(node: Node2D, state: RVGameState, font: Font, rect: Rect2) -> void:
	node.draw_string(font, rect.position + Vector2(24,34), "FORGECRAFT  F base  E add/upgrade  X chaos  Q seal  T refine  R shatter  W/S item", HORIZONTAL_ALIGNMENT_LEFT, -1, 16, Color(1.0,0.62,0.34))
	var item: Dictionary = focused_item(state)
	if item.is_empty():
		node.draw_string(font, rect.position + Vector2(42,90), "No backpack item. Press F to create a forge base.", HORIZONTAL_ALIGNMENT_LEFT, -1, 16, Color(0.90,0.84,0.72))
		return
	node.draw_string(font, rect.position + Vector2(42,86), str(item.get("name","Item")) + "  FP " + str(item.get("forging_potential",0)), HORIZONTAL_ALIGNMENT_LEFT, -1, 18, Color(1.0,0.84,0.55))
	var y: float = 126
	for affix in item.get("affixes", []):
		if typeof(affix) == TYPE_DICTIONARY:
			node.draw_string(font, rect.position + Vector2(62,y), str(affix.get("id","affix")) + "  T" + str(affix.get("tier",1)), HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.88,0.84,0.74))
			y += 26
	var sealed: Variant = item.get("sealed_affix", {})
	if typeof(sealed) == TYPE_DICTIONARY and not sealed.is_empty():
		node.draw_string(font, rect.position + Vector2(62,y), "SEALED: " + str(sealed.get("id","")) + " T" + str(sealed.get("tier",1)), HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.78,0.60,1.0))
	node.draw_string(font, rect.position + Vector2(560,86), "Glyphs: Hope " + str(state.glyph_counts.get("hope",0)) + " Chaos " + str(state.glyph_counts.get("chaos",0)) + " Despair " + str(state.glyph_counts.get("despair",0)), HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.90,0.84,0.72))
	node.draw_string(font, rect.position + Vector2(560,120), "Runes: Shatter " + str(state.rune_counts.get("shattering",0)) + " Refine " + str(state.rune_counts.get("refinement",0)), HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.90,0.84,0.72))
	node.draw_string(font, rect.position + Vector2(560,170), "Backpack: " + str(state.backpack.size()) + "  focus " + str(state.forge_focus_index + 1), HORIZONTAL_ALIGNMENT_LEFT, -1, 14, Color(0.90,0.84,0.72))

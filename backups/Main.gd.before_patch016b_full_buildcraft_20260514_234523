extends Node2D

# Relic Forge: Vaultbound
# Patch 016 coordinator: hub buildcraft rework.

var state: RVGameState = RVGameState.new()
var textures: Dictionary = {}
var autosave_timer: float = 0.0

func _ready() -> void:
	state.init()
	RVSaveSystem.load_into(state)
	state.init()
	RVHubSystem.rebuild_objects(state)
	state.enter_hub()
	state.add_notice("Forgehold loaded")
	set_process(true)
	set_process_unhandled_input(true)

func _process(delta: float) -> void:
	RVPlayerSystem.update(state, delta)
	RVSkillSystem.update(state, delta)
	if state.mode == "hub":
		RVHubSystem.update_focus(state)
	else:
		if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT):
			RVSkillSystem.cast_selected(state, get_global_mouse_position())
		RVCombatSystem.update(state, delta)
	if state.notice_time > 0.0:
		state.notice_time = max(0.0, state.notice_time - delta)
	autosave_timer += delta
	if autosave_timer >= 10.0:
		autosave_timer = 0.0
		RVSaveSystem.save(state)
	queue_redraw()

func _notification(what: int) -> void:
	if what == NOTIFICATION_WM_CLOSE_REQUEST:
		RVSaveSystem.save(state)

func _unhandled_input(event) -> void:
	if event is InputEventKey:
		var key: InputEventKey = event
		if key.pressed and not key.echo:
			_handle_key(key.keycode)
	if event is InputEventMouseButton:
		var mb: InputEventMouseButton = event
		if mb.pressed and mb.button_index == MOUSE_BUTTON_LEFT and state.mode == "combat":
			RVSkillSystem.cast_selected(state, get_global_mouse_position())

func _handle_key(keycode: int) -> void:
	if state.panel_mode != "":
		if _handle_panel_key(keycode):
			return
	if keycode >= KEY_1 and keycode <= KEY_6:
		var index: int = keycode - KEY_1
		if state.mode == "hub":
			var names: Array = RVSkillGemDB.active_skill_names()
			if index < names.size(): RVSkillGemSystem.toggle_skill_loadout(state, str(names[index]))
		elif index < state.active_skills.size():
			state.selected_skill = index
		return
	if keycode == KEY_Q and state.mode == "combat":
		state.selected_skill = posmod(state.selected_skill - 1, state.active_skills.size())
		return
	if keycode == KEY_E and state.mode == "combat":
		state.selected_skill = posmod(state.selected_skill + 1, state.active_skills.size())
		return
	if keycode == KEY_SPACE and state.mode == "combat":
		RVSkillSystem.cast_selected(state, get_global_mouse_position())
		return
	if keycode == KEY_E and state.mode == "hub":
		RVHubSystem.interact_primary(state)
		RVSaveSystem.save(state)
		return
	if keycode == KEY_X and state.mode == "hub":
		RVHubSystem.interact_secondary(state)
		RVSaveSystem.save(state)
		return
	if keycode == KEY_P and state.mode == "hub":
		state.panel_mode = "passive_tree"
		return
	if keycode == KEY_K and state.mode == "hub":
		state.panel_mode = "skill_gems"
		return
	if keycode == KEY_C and state.mode == "hub":
		state.panel_mode = "crafting"
		return
	if keycode == KEY_ESCAPE:
		if state.panel_mode != "":
			state.panel_mode = ""
		elif state.mode == "combat":
			state.enter_hub()
			state.add_notice("Returned to Forgehold")
			RVSaveSystem.save(state)
		return
	if keycode == KEY_F5:
		RVSaveSystem.save(state)
		state.add_notice("Saved")
		return

func _handle_panel_key(keycode: int) -> bool:
	if keycode == KEY_ESCAPE:
		state.panel_mode = ""
		return true
	if state.panel_mode == "passive_tree":
		if keycode == KEY_Q:
			RVPassiveTreeSystem.cycle_selected(state, -1); return true
		if keycode == KEY_E:
			RVPassiveTreeSystem.cycle_selected(state, 1); return true
		if keycode == KEY_ENTER or keycode == KEY_KP_ENTER:
			RVPassiveTreeSystem.allocate_selected(state); RVSaveSystem.save(state); return true
		if keycode == KEY_BACKSPACE:
			RVPassiveTreeSystem.refund_last(state); RVSaveSystem.save(state); return true
	elif state.panel_mode == "skill_gems":
		if keycode == KEY_Q:
			RVSkillGemSystem.cycle_skill_cursor(state, -1); return true
		if keycode == KEY_E:
			RVSkillGemSystem.cycle_skill_cursor(state, 1); return true
		if keycode == KEY_W:
			RVSkillGemSystem.cycle_support_cursor(state, -1); return true
		if keycode == KEY_S:
			RVSkillGemSystem.cycle_support_cursor(state, 1); return true
		if keycode == KEY_ENTER or keycode == KEY_KP_ENTER:
			RVSkillGemSystem.socket_selected_support(state); RVSaveSystem.save(state); return true
		if keycode == KEY_X:
			RVSkillGemSystem.remove_last_support(state); RVSaveSystem.save(state); return true
		if keycode >= KEY_1 and keycode <= KEY_6:
			var names: Array = RVSkillGemDB.active_skill_names()
			var index: int = keycode - KEY_1
			if index < names.size(): RVSkillGemSystem.toggle_skill_loadout(state, str(names[index])); RVSaveSystem.save(state)
			return true
	elif state.panel_mode == "crafting":
		if keycode == KEY_F:
			RVCraftingSystem.craft_base(state); RVSaveSystem.save(state); return true
		if keycode == KEY_E:
			RVCraftingSystem.add_or_upgrade_affix(state); RVSaveSystem.save(state); return true
		if keycode == KEY_X:
			RVCraftingSystem.chaos_reroll_affix(state); RVSaveSystem.save(state); return true
		if keycode == KEY_Q:
			RVCraftingSystem.seal_affix(state); RVSaveSystem.save(state); return true
		if keycode == KEY_R:
			RVCraftingSystem.shatter_focused_item(state); RVSaveSystem.save(state); return true
		if keycode == KEY_W:
			RVCraftingSystem.focus_next(state, -1); return true
		if keycode == KEY_S:
			RVCraftingSystem.focus_next(state, 1); return true
	return false

func _draw() -> void:
	RVRenderSystem.draw_world(self, state, textures)

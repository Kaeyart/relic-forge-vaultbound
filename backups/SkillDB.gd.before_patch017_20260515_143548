class_name RVSkillDB
extends RefCounted

static func names() -> Array:
	return RVSkillGemDB.active_skill_names()

static func data(skill: String) -> Dictionary:
	var d: Dictionary = RVSkillGemDB.active_data(skill)
	if d.is_empty():
		return {}
	return {"cost": d.get("base_cost", 10.0), "cooldown": d.get("base_cd", 0.5), "damage": d.get("base_damage", 10.0), "tags": d.get("tags", []), "color": d.get("color", Color(0.9, 0.84, 0.7))}

static func color(skill: String) -> Color:
	var d: Dictionary = RVSkillGemDB.active_data(skill)
	return d.get("color", Color(0.90, 0.84, 0.70))

static func tags(skill: String) -> Array:
	var d: Dictionary = RVSkillGemDB.active_data(skill)
	return d.get("tags", [])

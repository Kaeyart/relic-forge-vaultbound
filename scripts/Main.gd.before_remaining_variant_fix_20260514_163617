func _ready() -> void:
	rng.randomize()
	_setup_ui()
	equipped["weapon"] = ITEM_POOL[0].duplicate(true)
	_reset_run()
	log_msg("Patch 003 loaded: cleanup, skill drafts, respec, longer route pacing, and cascade build engines are active.")
	log_msg("Start by drafting 2 skills. Press G for the guide, K for skill trees, O to respec/refund trees.")

func _setup_ui() -> void:
	var layer := CanvasLayer.new()
	add_child(layer)

	hud_label = Label.new()
	hud_label.position = Vector2(18, 12)
	hud_label.size = Vector2(600, 120)
	layer.add_child(hud_label)

	build_label = Label.new()
	build_label.position = Vector2(930, 12)
	build_label.size = Vector2(330, 600)
	build_label.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
	layer.add_child(build_label)

	choice_label = Label.new()
	choice_label.position = Vector2(245, 145)
	choice_label.size = Vector2(790, 380)
	choice_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	choice_label.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	choice_label.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
	layer.add_child(choice_label)

	log_label = Label.new()
	log_label.position = Vector2(18, 610)
	log_label.size = Vector2(850, 94)
	log_label.autowrap_mode = TextServer.AUTOWRAP_WORD_SMART
	layer.add_child(log_label)

	loot_label = Label.new()
	loot_label.position = Vector2(350, 52)
	loot_label.size = Vector2(590, 60)
	loot_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	layer.add_child(loot_label)

	help_label = Label.new()
	help_label.position = Vector2(18, 688)
	help_label.size = Vector2(1240, 24)
	help_label.text = "WASD move | Mouse aim | Left click cast | 1-6 skill/choice | Q dash | E interact/pick/equip | TAB panel | I inventory | K skill tree | P build | M dungeon | F test item | G guide | O respec | R restart"
	layer.add_child(help_label)

func reset_build_state() -> void:
	active_skills.clear()
	selected_skill = 0
	inventory.clear()
	owned_passives.clear()
	passive_points = 0
	for slot in equipped.keys():
		equipped[slot] = null
	skill_points.clear()
	skill_xp.clear()
	skill_xp_next.clear()
	owned_skill_nodes.clear()
	for s in all_skill_names:
		skill_points[s] = 0
		skill_xp[s] = 0.0
		skill_xp_next[s] = 55.0
		owned_skill_nodes[s] = []

func start_opening_skill_draft() -> void:
	run_state = "reward"
	choice_mode = "skill_draft"
	starter_picks_remaining = 2
	skill_draft_returns_to_route = false
	make_skill_draft_choices()
	log_msg("Run start: choose 2 starting skills. You begin almost empty and build upward.")

func _reset_run() -> void:
	reset_build_state()
	player_pos = WORLD_CENTER
	player_hp = get_stats()["max_hp"]
	player_mana = get_stats()["max_mana"]
	dash_time = 0.0
	dash_cooldown = 0.0
	invuln_time = 0.0
	focus_time = 0.0
	guard_time = 0.0
	skill_cd.clear()
	enemies.clear()
	projectiles.clear()
	enemy_projectiles.clear()
	zones.clear()
	loot.clear()
	obstacles.clear()
	traps.clear()
	chests.clear()
	room_decor.clear()
	floating_text.clear()
	minions.clear()
	delayed_casts.clear()
	level = 1
	xp = 0.0
	xp_to_next = 90.0
	gold = 0
	room_index = 1
	run_depth = 0
	last_room_rewarded_skill_point = 0
	rooms_cleared = 0
	kills = 0
	run_state = "reward"
	choice_mode = ""
	current_room = {"name":"Draft Chamber", "type":"Draft", "biome":"Hub", "mods":[], "threat":0.0, "elite":false, "treasure":false}
	start_opening_skill_draft()

func _process(delta: float) -> void:
	_update_timers(delta)
	_handle_continuous_input(delta)
	if run_state == "combat" and choice_mode == "":
		_update_delayed_casts(delta)
		_update_projectiles(delta)
		_update_enemy_projectiles(delta)
		_update_zones(delta)
		_update_room_hazards(delta)
		_update_enemies(delta)
		_update_minions(delta)
		_update_statuses(delta)
		_check_room_clear()
	_update_loot_tracking()
	_update_floating_text(delta)
	_update_ui()
	queue_redraw()

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey and event.pressed and not event.echo:
		if event.keycode == KEY_R:
			_reset_run()
			log_msg("Run restarted.")
			return
		if event.keycode == KEY_TAB:
			build_panel_visible = not build_panel_visible
			return
		if event.keycode == KEY_I:
			open_panel = "inventory"
			build_panel_visible = true
			return
		if event.keycode == KEY_K:
			open_panel = "skilltree"
			build_panel_visible = true
			return
		if event.keycode == KEY_P:
			open_panel = "build"
			build_panel_visible = true
			return
		if event.keycode == KEY_M:
			open_panel = "dungeon"
			build_panel_visible = true
			return
		if event.keycode == KEY_G:
			open_panel = "guide"
			build_panel_visible = true
			return
		if event.keycode == KEY_O:
			respec_all_trees()
			return
		if event.keycode == KEY_F:
			_drop_item(player_pos + Vector2(rng.randf_range(-80, 80), rng.randf_range(-60, 60)), true)
			return
		if event.keycode == KEY_E:
			interact_or_equip()
			return
		if event.keycode in [KEY_1, KEY_2, KEY_3, KEY_4, KEY_5, KEY_6, KEY_7, KEY_8, KEY_9]:
			var idx := int(event.keycode - KEY_1)
			if choice_mode != "":
				choose_active_option(idx)
			else:
				if open_panel == "skilltree" and idx < 9:
					if active_skills.size() > 0:
						unlock_skill_node_by_index(active_skills[selected_skill], idx)
					return
				if open_panel == "inventory" and idx < inventory.size():
					equip_inventory_index(idx)
					return
				if idx < active_skills.size():
					selected_skill = idx
					log_msg("Selected skill: " + active_skills[selected_skill])

func _handle_continuous_input(delta: float) -> void:
	if run_state == "game_over" or run_state == "victory":
		return
	var stats := get_stats()
	if choice_mode != "":
		return
	var move := Vector2.ZERO
	if Input.is_key_pressed(KEY_W):
		move.y -= 1.0
	if Input.is_key_pressed(KEY_S):
		move.y += 1.0
	if Input.is_key_pressed(KEY_A):
		move.x -= 1.0
	if Input.is_key_pressed(KEY_D):
		move.x += 1.0
	if move.length() > 0.0:
		move = move.normalized()

	if Input.is_key_pressed(KEY_Q) and dash_cooldown <= 0.0 and dash_time <= 0.0:
		dash_dir = move
		if dash_dir.length() <= 0.01:
			dash_dir = aim_dir()
		dash_dir = dash_dir.normalized()
		dash_time = 0.16
		invuln_time = 0.22
		dash_cooldown = max(0.28, 0.82 + stats.get("dash_recovery", 0.0))
		if has_flag(stats, "dash_thunder"):
			spawn_explosion(player_pos, 135.0, 16.0, ["Lightning", "Area", "Dash"], "dash thunder")
		check_perfect_dodge_focus(stats)

	var next_pos := player_pos
	if dash_time > 0.0:
		next_pos += dash_dir * 690.0 * delta
	else:
		next_pos += move * stats["move_speed"] * delta
	next_pos = clamp_to_arena(next_pos, player_radius)
	player_pos = resolve_obstacle_collision(next_pos, player_radius)

	if Input.is_mouse_button_pressed(MOUSE_BUTTON_LEFT) and active_skills.size() > 0:
		cast_skill(active_skills[selected_skill])

func _update_timers(delta: float) -> void:
	var stats := get_stats()
	for k in skill_cd.keys():
		skill_cd[k] = max(0.0, skill_cd[k] - delta)
	dash_time = max(0.0, dash_time - delta)
	dash_cooldown = max(0.0, dash_cooldown - delta)
	invuln_time = max(0.0, invuln_time - delta)
	focus_time = max(0.0, focus_time - delta)
	guard_time = max(0.0, guard_time - delta)
	player_mana = min(stats["max_mana"], player_mana + stats["mana_regen"] * delta)
	if player_hp > stats["max_hp"]:
		player_hp = stats["max_hp"]

func _update_delayed_casts(delta: float) -> void:
	for i in range(delayed_casts.size() - 1, -1, -1):
		delayed_casts[i]["time"] -= delta
		if delayed_casts[i]["time"] <= 0.0:
			var item = delayed_casts[i]
			_cast_skill_now(item["skill"], true, item.get("power", 0.55), int(item.get("chain_depth", 1)))
			delayed_casts.remove_at(i)

func cast_skill(skill_name: String) -> void:
	if run_state != "combat" or choice_mode != "":
		return
	if not SKILLS.has(skill_name):
		return
	var skill = SKILLS[skill_name]
	var stats := get_stats()
	var cd: float = float(skill["cooldown"]) * max(0.18, 1.0 - stats["cooldown_reduction"])
	if skill_cd.get(skill_name, 0.0) > 0.0:
		return
	var cost := float(skill.get("cost", 0.0))
	var can_cast := true
	if player_mana >= cost:
		player_mana -= cost
	elif has_flag(stats, "blood_cast") and has_tag(skill["tags"], "Spell") and player_hp > 22.0:
		player_hp -= max(6.0, cost * 0.75)
		floating("blood cast", player_pos + Vector2(0, -28), Color(0.9, 0.1, 0.12))
	else:
		can_cast = false
	if not can_cast:
		return
	skill_cd[skill_name] = cd
	_cast_skill_now(skill_name, false, 1.0, 0)
	gain_skill_xp(skill_name, 6.0 * (1.45 if has_flag(get_stats(), "selected_skill_xp_bonus") else 1.0))
	if has_flag(stats, "blood_orbs") and has_tag(skill["tags"], "Spell") and player_hp < stats["max_hp"] * 0.72:
		minions.append({"pos": player_pos, "life": 5.5, "cd": 0.25, "angle": rng.randf() * TAU, "kind":"blood"})
		floating("blood orb", player_pos + Vector2(0, -56), Color(1.0, 0.1, 0.15))
	cast_counter += 1
	if has_flag(stats, "skill_echo") and cast_counter % 3 == 0:
		queue_chain_skill(skill_name, 0.12, 0.55, 1)
		floating("echo armed", player_pos + Vector2(0, -42), Color(0.74, 0.69, 1.0))

func _cast_skill_now(skill_name: String, is_echo: bool, power_scale: float, chain_depth := 0) -> void:
	var stats := get_stats()
	var skill = SKILLS[skill_name]
	var base_tags = skill["tags"].duplicate()
	var power := power_scale
	if focus_time > 0.0 and not is_echo:
		power *= 1.55
		focus_time = 0.0
		floating("FOCUS", player_pos + Vector2(0, -48), Color(1.0, 0.95, 0.35))
	if has_flag(stats, "blood_cast") and has_tag(base_tags, "Spell") and player_mana < float(skill.get("cost", 0.0)) * 0.5:
		power *= 1.25
	match skill_name:
		"Fireball":
			if has_flag(stats, "fire_meteor") and has_flag(stats, "meteor_ready"):
				var target_m := player_pos + aim_dir() * 260.0
				zones.append({"pos": clamp_to_arena(target_m, 70.0), "radius": 92.0, "time": 0.62, "duration": 0.82, "damage": scaled_damage(float(skill["damage"]) * power * 2.15, ["Fire", "Area", "Spell", "Burn"], stats), "tags": ["Fire", "Area", "Spell", "Burn"], "triggered": false, "visual": "METEOR", "color": Color(1.0, 0.32, 0.06, 0.30)})
				floating("meteor", target_m + Vector2(0, -40), Color(1.0, 0.55, 0.20))
			else:
				var count := int(max(1, stats["projectile_count"]))
				if has_flag(stats, "fire_split"):
					count += 2
				var spread := 0.13 * float(count - 1)
				for i in range(count):
					var a: float = aim_dir().angle() - spread * 0.5 + (spread / max(1, count - 1)) * i
					spawn_projectile(player_pos + vec_from_angle(a) * 20.0, vec_from_angle(a) * float(skill["speed"]), scaled_damage(float(skill["damage"]) * power, base_tags, stats), float(skill["radius"]), base_tags, "Fireball", 1.2)
		"Storm Lance":
			var count2 := int(max(1, stats["projectile_count"] - 1))
			var spread2 := 0.08 * float(count2 - 1)
			for j in range(count2):
				var a2: float = aim_dir().angle() - spread2 * 0.5 + (spread2 / max(1, count2 - 1)) * j
				spawn_projectile(player_pos + vec_from_angle(a2) * 20.0, vec_from_angle(a2) * float(skill["speed"]), scaled_damage(float(skill["damage"]) * power, base_tags, stats), float(skill["radius"]), base_tags, "Storm Lance", 0.95)
		"Cleave":
			cast_cleave(scaled_damage(float(skill["damage"]) * power, base_tags, stats), base_tags, stats)
		"Frost Nova":
			var before_hits := count_enemies_in_radius(player_pos, float(skill["radius"]))
			spawn_explosion(player_pos, float(skill["radius"]), scaled_damage(float(skill["damage"]) * power, base_tags, stats), base_tags, "Frost Nova")
			if has_flag(stats, "nova_field"):
				zones.append({"pos": player_pos, "radius": float(skill["radius"]) * 0.72, "time": 0.15, "duration": 2.2, "tick": 0.45, "tick_cd": 0.0, "damage": scaled_damage(5.0 * power, ["Cold", "Area", "Spell"], stats), "tags": ["Cold", "Area", "Spell", "Freeze"], "visual": "ice field", "color": Color(0.36, 0.74, 1.0, 0.18)})
			if has_flag(stats, "nova_focus") and before_hits >= 2:
				focus_time = 2.0 + stats.get("focus_duration", 0.0)
				floating("calm focus", player_pos + Vector2(0, -52), Color(0.75, 0.95, 1.0))
		"Void Rift":
			var target := player_pos + aim_dir() * 135.0
			zones.append({"pos": target, "radius": float(skill["radius"]), "time": 0.85, "duration": 1.15, "damage": scaled_damage(float(skill["damage"]) * power, base_tags, stats), "tags": base_tags.duplicate(), "triggered": false, "pull": has_flag(stats, "rift_pull"), "visual": "Void Rift", "color": Color(0.55, 0.18, 0.95, 0.28)})
		"Blade Trap":
			place_blade_trap(player_pos + aim_dir() * 78.0, scaled_damage(float(skill["damage"]) * power, base_tags, stats), base_tags, stats, 1.0)
	trigger_chain_reactions(skill_name, is_echo, power, chain_depth)

func queue_chain_skill(skill_name: String, delay: float, power: float, depth: int) -> void:
	if not SKILLS.has(skill_name):
		return
	delayed_casts.append({"skill": skill_name, "time": delay, "power": power, "chain_depth": depth})
	floating("queue " + skill_name, player_pos + Vector2(0, -66), Color(0.84, 0.74, 1.0))
	var stats := get_stats()
	if has_flag(stats, "chain_mana_refund"):
		player_mana = min(stats["max_mana"], player_mana + 3.0)

func trigger_chain_reactions(source_skill: String, is_echo: bool, power: float, chain_depth: int) -> void:
	var stats := get_stats()
	if chain_depth >= 4:
		return
	if is_echo and not has_flag(stats, "cascade_engine"):
		return
	var next_depth := chain_depth + 1
	if source_skill == "Fireball":
		if has_flag(stats, "fire_calls_lance"): queue_chain_skill("Storm Lance", 0.08, 0.45 * power, next_depth)
		if has_flag(stats, "fire_calls_nova"): queue_chain_skill("Frost Nova", 0.16, 0.36 * power, next_depth)
	if source_skill == "Frost Nova":
		if has_flag(stats, "nova_calls_fire"): queue_chain_skill("Fireball", 0.10, 0.52 * power, next_depth)
		if has_flag(stats, "nova_calls_lance"): queue_chain_skill("Storm Lance", 0.12, 0.48 * power, next_depth)
	if source_skill == "Storm Lance":
		if has_flag(stats, "lance_calls_nova"): queue_chain_skill("Frost Nova", 0.12, 0.40 * power, next_depth)
		if has_flag(stats, "lance_calls_fire"): queue_chain_skill("Fireball", 0.10, 0.46 * power, next_depth)
		if has_flag(stats, "lance_calls_rift"): queue_chain_skill("Void Rift", 0.16, 0.38 * power, next_depth)
	if source_skill == "Void Rift":
		if has_flag(stats, "rift_calls_trap"): queue_chain_skill("Blade Trap", 0.10, 0.48 * power, next_depth)
		if has_flag(stats, "rift_calls_fire"): queue_chain_skill("Fireball", 0.18, 0.50 * power, next_depth)
		if has_flag(stats, "rift_calls_lance"): queue_chain_skill("Storm Lance", 0.14, 0.46 * power, next_depth)
	if source_skill == "Blade Trap":
		if has_flag(stats, "trap_calls_rift"): queue_chain_skill("Void Rift", 0.10, 0.44 * power, next_depth)
		if has_flag(stats, "trap_calls_fire"): queue_chain_skill("Fireball", 0.12, 0.44 * power, next_depth)
		if has_flag(stats, "trap_calls_cleave"): queue_chain_skill("Cleave", 0.08, 0.36 * power, next_depth)
	if source_skill == "Cleave":
		if has_flag(stats, "cleave_calls_trap"): queue_chain_skill("Blade Trap", 0.10, 0.44 * power, next_depth)
		if has_flag(stats, "cleave_calls_lance"): queue_chain_skill("Storm Lance", 0.09, 0.42 * power, next_depth)
	if has_flag(stats, "cascade_engine") and rng.randf() < (0.20 + 0.08 * float(chain_depth)):
		var pool := all_skill_names.duplicate()
		pool.erase(source_skill)
		queue_chain_skill(pool[rng.randi_range(0, pool.size() - 1)], 0.18, 0.34 * power, next_depth)
	if has_flag(stats, "fivefold_cascade") and not is_echo and cast_counter > 0 and cast_counter % 5 == 0:
		for s in all_skill_names:
			if s != source_skill:
				queue_chain_skill(s, 0.08 + 0.04 * float(all_skill_names.find(s)), 0.28 * power, next_depth)

func cast_cleave(damage: float, tags: Array, stats: Dictionary) -> void:
	var dir: Vector2 = aim_dir()
	var arc := float(SKILLS["Cleave"]["arc"])
	var range_v := float(SKILLS["Cleave"]["range"])
	for e in enemies:
		var to_e: Vector2 = e["pos"] - player_pos
		if to_e.length() <= range_v + e["radius"]:
			var diff := abs(wrapf(to_e.angle() - dir.angle(), -PI, PI))
			if diff <= arc * 0.5:
				deal_damage(e, damage, tags, player_pos, "Cleave")
	if has_flag(stats, "cleave_circle"):
		for e2 in enemies:
			if e2["pos"].distance_to(player_pos) <= range_v * 0.72 + e2["radius"]:
				deal_damage(e2, damage * 0.42, tags, player_pos, "Cleave Circle")
	if has_flag(stats, "cleave_guard"):
		guard_time = 0.75
		floating("guard", player_pos + Vector2(0, -48), Color(0.82, 0.88, 1.0))
	zones.append({"pos": player_pos + dir * 62.0, "radius": 58.0, "time": 0.10, "duration": 0.10, "visual": "slash", "color": Color(1.0, 0.78, 0.38, 0.36)})
	if has_flag(stats, "cleave_wave"):
		spawn_projectile(player_pos + dir * 24.0, dir * 520.0, damage * 0.65, 13.0, ["Physical", "Melee", "Slash", "Projectile"], "Cleave Wave", 0.55)

func spawn_projectile(pos: Vector2, vel: Vector2, damage: float, radius: float, tags: Array, source_skill: String, life: float) -> void:
	projectiles.append({
		"pos": pos, "vel": vel, "damage": damage, "radius": radius, "tags": tags.duplicate(),
		"skill": source_skill, "life": life, "hit_ids": {}, "pierce": 0
	})

func _update_projectiles(delta: float) -> void:
	for i in range(projectiles.size() - 1, -1, -1):
		var p = projectiles[i]
		p["life"] -= delta
		p["pos"] += p["vel"] * delta
		var remove: bool = p["life"] <= 0.0 or not ARENA.grow(35.0).has_point(p["pos"]) or point_hits_obstacle(p["pos"], p["radius"])
		for e in enemies:
			if p["hit_ids"].has(e["id"]):
				continue
			if p["pos"].distance_to(e["pos"]) <= p["radius"] + e["radius"]:
				p["hit_ids"][e["id"]] = true
				deal_damage(e, p["damage"], p["tags"], p["pos"], str(p["skill"]))
				if has_tag(p["tags"], "Fire"):
					spawn_explosion(p["pos"], 44.0, p["damage"] * 0.38, ["Fire", "Area", "Burn"], "impact")
				if has_tag(p["tags"], "Lightning"):
					var stats_now := get_stats()
					chain_lightning(e, p["damage"] * 0.58, stats_now)
					if has_flag(stats_now, "lance_fork") and str(p.get("skill", "")) == "Storm Lance":
						for fork_angle in [-0.42, 0.42]:
							var fd: Vector2 = p["vel"].normalized().rotated(fork_angle)
							spawn_projectile(p["pos"] + fd * 12.0, fd * 610.0, p["damage"] * 0.44, max(5.0, p["radius"] * 0.72), ["Lightning", "Projectile", "Spell", "Chain"], "Forked Lance", 0.52)
				if int(p.get("pierce", 0)) <= 0:
					remove = true
				else:
					p["pierce"] -= 1
				break
		if remove:
			projectiles.remove_at(i)

func _update_enemy_projectiles(delta: float) -> void:
	for i in range(enemy_projectiles.size() - 1, -1, -1):
		var p = enemy_projectiles[i]
		p["life"] -= delta
		p["pos"] += p["vel"] * delta
		var remove: bool = p["life"] <= 0.0 or not ARENA.grow(45.0).has_point(p["pos"])
		if p["pos"].distance_to(player_pos) <= p["radius"] + player_radius:
			player_take_damage(p["damage"], p["pos"])
			remove = true
		if remove:
			enemy_projectiles.remove_at(i)

func spawn_enemy_projectile(pos: Vector2, vel: Vector2, damage: float, radius: float, color: Color, life: float) -> void:
	enemy_projectiles.append({"pos": pos, "vel": vel, "damage": damage, "radius": radius, "color": color, "life": life})

func spawn_explosion(pos: Vector2, radius: float, damage: float, tags: Array, label: String) -> void:
	zones.append({"pos": pos, "radius": radius, "time": 0.08, "duration": 0.18, "damage": damage, "tags": tags.duplicate(), "triggered": false, "visual": label, "color": zone_color(tags)})

func _update_zones(delta: float) -> void:
	for i in range(zones.size() - 1, -1, -1):
		var z = zones[i]
		z["time"] -= delta
		if z.get("pull", false):
			for e_pull in enemies:
				var to_center: Vector2 = z["pos"] - e_pull["pos"]
				if to_center.length() < z["radius"] * 1.35 and to_center.length() > 1.0:
					e_pull["pos"] += to_center.normalized() * 125.0 * delta
		if z.has("tick"):
			z["tick_cd"] = max(0.0, float(z.get("tick_cd", 0.0)) - delta)
			if z["tick_cd"] <= 0.0:
				z["tick_cd"] = float(z["tick"])
				for e_tick in enemies:
					if e_tick["pos"].distance_to(z["pos"]) <= z["radius"] + e_tick["radius"]:
						deal_damage(e_tick, z["damage"], z["tags"], z["pos"], str(z.get("visual", "field")))
		if z.has("damage") and not z.get("triggered", false) and z["time"] <= 0.0:
			z["triggered"] = true
			for e in enemies:
				if e["pos"].distance_to(z["pos"]) <= z["radius"] + e["radius"]:
					deal_damage(e, z["damage"], z["tags"], z["pos"], str(z.get("visual", "zone")))
		z["duration"] -= delta
		if z["duration"] <= 0.0:
			zones.remove_at(i)

func _update_enemies(delta: float) -> void:
	for e in enemies:
		if e["hp"] <= 0.0:
			continue
		var data = ENEMY_TYPES[e["type"]]
		var role := str(data["role"])
		var speed := float(data["speed"])
		if e["statuses"].has("freeze"):
			speed *= 0.25
		var to_player: Vector2 = player_pos - e["pos"]
		var dist: float = to_player.length()
		var dir: Vector2 = Vector2.ZERO
		if dist > 0.01:
			dir = to_player / dist
		e["ai_cd"] = max(0.0, e["ai_cd"] - delta)

		if role == "chaser":
			e["pos"] += dir * speed * delta
			if dist <= e["radius"] + player_radius + 5.0 and e["ai_cd"] <= 0.0:
				player_take_damage(float(data["damage"]), e["pos"])
				e["ai_cd"] = 0.65
		elif role == "shooter":
			if dist < 260.0:
				e["pos"] -= dir * speed * 0.75 * delta
			elif dist > 380.0:
				e["pos"] += dir * speed * delta
			if e["ai_cd"] <= 0.0:
				spawn_enemy_projectile(e["pos"] + dir * 18.0, dir * 330.0, float(data["damage"]), 8.0, Color(0.92, 0.86, 0.62), 2.2)
				e["ai_cd"] = 1.35
		elif role == "spitter":
			if dist > 230.0:
				e["pos"] += dir * speed * delta
			else:
				e["pos"] -= dir.rotated(0.7) * speed * 0.35 * delta
			if e["ai_cd"] <= 0.0:
				var target := player_pos
				zones.append({"pos": target, "radius": 52.0, "time": 0.55, "duration": 0.72, "damage": float(data["damage"]) + 3.0, "tags": ["Fire", "Area"], "triggered": false, "visual": "spit warning", "color": Color(1.0, 0.25, 0.05, 0.28)})
				e["ai_cd"] = 1.7
		elif role == "hound":
			e["pos"] += dir * speed * delta
			if dist <= e["radius"] + player_radius + 8.0 and e["ai_cd"] <= 0.0:
				player_take_damage(float(data["damage"]), e["pos"])
				apply_player_poison(1.8)
				e["ai_cd"] = 0.55
		elif role == "knight":
			if dist > 88.0:
				e["pos"] += dir * speed * delta
			if e["ai_cd"] <= 0.0 and dist < 125.0:
				zones.append({"pos": e["pos"] + dir * 46.0, "radius": 46.0, "time": 0.32, "duration": 0.48, "damage": float(data["damage"]) + 3.0, "tags": ["Physical", "Melee", "Slash"], "triggered": false, "visual": "knight cleave", "color": Color(0.95, 0.88, 0.72, 0.22)})
				e["ai_cd"] = 1.2
		elif role == "acolyte":
			if dist < 220.0:
				e["pos"] -= dir * speed * 0.65 * delta
			elif dist > 430.0:
				e["pos"] += dir * speed * delta
			if e["ai_cd"] <= 0.0:
				zones.append({"pos": player_pos + Vector2(rng.randf_range(-32,32), rng.randf_range(-32,32)), "radius": 58.0, "time": 0.62, "duration": 0.82, "damage": float(data["damage"]) + room_index, "tags": ["Void", "Area", "Curse"], "triggered": false, "visual": "mirror hex", "color": Color(0.68, 0.26, 1.0, 0.25)})
				e["ai_cd"] = 1.55
		elif role == "brute":
			if e.get("charge_time", 0.0) > 0.0:
				e["charge_time"] -= delta
				if e["charge_time"] <= 0.0:
					e["charge_vel"] = dir * 520.0
					zones.append({"pos": e["pos"], "radius": 38.0, "time": 0.12, "duration": 0.18, "visual": "brute slam", "color": Color(1.0, 0.8, 0.35, 0.25)})
			elif e.get("charge_vel", Vector2.ZERO).length() > 1.0:
				e["pos"] += e["charge_vel"] * delta
				e["charge_vel"] = e["charge_vel"].move_toward(Vector2.ZERO, 820.0 * delta)
				if dist <= e["radius"] + player_radius + 12.0:
					player_take_damage(float(data["damage"]) + 8.0, e["pos"])
					e["charge_vel"] = Vector2.ZERO
			else:
				e["pos"] += dir * speed * delta
				if dist < 285.0 and e["ai_cd"] <= 0.0:
					e["charge_time"] = 0.55
					e["ai_cd"] = 2.25
					zones.append({"pos": e["pos"] + dir * 80.0, "radius": 52.0, "time": 0.55, "duration": 0.65, "visual": "charge tell", "color": Color(1.0, 0.75, 0.22, 0.28)})
		elif role == "boss":
			_update_boss(e, delta, dir, dist)

		e["pos"].x = clamp(e["pos"].x, ARENA.position.x + e["radius"], ARENA.end.x - e["radius"])
		e["pos"].y = clamp(e["pos"].y, ARENA.position.y + e["radius"], ARENA.end.y - e["radius"])
		e["pos"] = resolve_obstacle_collision(e["pos"], e["radius"])

func _update_boss(e: Dictionary, delta: float, dir: Vector2, dist: float) -> void:
	var data = ENEMY_TYPES[e["type"]]
	e["pos"] += dir * float(data["speed"]) * 0.42 * delta
	if e["ai_cd"] <= 0.0:
		var pattern := rng.randi_range(0, 2)
		if pattern == 0:
			for n in range(12):
				var a: float = TAU * float(n) / 12.0
				spawn_enemy_projectile(e["pos"] + vec_from_angle(a) * 32.0, vec_from_angle(a) * 250.0, 10.0 + room_index, 8.0, Color(0.77, 0.32, 1.0), 3.0)
			log_msg("Vault Warden releases a radial curse pattern.")
		elif pattern == 1:
			for n2 in range(4):
				var off := Vector2(rng.randf_range(-260, 260), rng.randf_range(-170, 170))
				zones.append({"pos": player_pos + off * 0.25, "radius": 68.0, "time": 0.72, "duration": 0.92, "damage": 18.0 + room_index, "tags": ["Void", "Area"], "triggered": false, "visual": "warden sigil", "color": Color(0.65, 0.16, 1.0, 0.26)})
			log_msg("Vault Warden marks the floor. Move.")
		else:
			spawn_enemy("Ash Grunt", e["pos"] + Vector2(rng.randf_range(-90, 90), rng.randf_range(-90, 90)))
			spawn_enemy("Bone Archer", e["pos"] + Vector2(rng.randf_range(-110, 110), rng.randf_range(-110, 110)))
			log_msg("Vault Warden calls reinforcements.")
		e["ai_cd"] = 2.15
	if dist <= e["radius"] + player_radius + 8.0:
		player_take_damage(float(data["damage"]), e["pos"])
	for e_fix in enemies:
		e_fix["pos"] = clamp_to_arena(e_fix["pos"], e_fix["radius"])
		e_fix["pos"] = resolve_obstacle_collision(e_fix["pos"], e_fix["radius"])

func _update_statuses(delta: float) -> void:
	for e in enemies:
		var statuses: Dictionary = e["statuses"]
		var keys := statuses.keys()
		for s in keys:
			var st = statuses[s]
			st["time"] -= delta
			if s == "burn" or s == "bleed" or s == "poison":
				var tick := float(st.get("dps", 0.0)) * delta
				e["hp"] -= tick
				if rng.randf() < 0.12:
					floating(str(s), e["pos"] + Vector2(rng.randf_range(-12, 12), -30), status_color(s))
			if st["time"] <= 0.0:
				statuses.erase(s)
	for i in range(enemies.size() - 1, -1, -1):
		if enemies[i]["hp"] <= 0.0:
			on_enemy_death(enemies[i])
			enemies.remove_at(i)

func _update_minions(delta: float) -> void:
	for i in range(minions.size() - 1, -1, -1):
		var m = minions[i]
		m["life"] -= delta
		if m["life"] <= 0.0:
			minions.remove_at(i)
			continue
		var orbit_angle := float(m.get("angle", 0.0)) + delta * 2.6
		m["angle"] = orbit_angle
		m["pos"] = player_pos + vec_from_angle(orbit_angle) * 52.0
		m["cd"] = max(0.0, m["cd"] - delta)
		if m["cd"] <= 0.0:
			var target := nearest_enemy(m["pos"], 460.0)
			if target != null:
				var dir: Vector2 = (target["pos"] - m["pos"]).normalized()
				if str(m.get("kind", "bone")) == "blood":
					spawn_projectile(m["pos"], dir * 560.0, scaled_damage(10.0, ["Physical", "Projectile", "Minion", "Blood"], get_stats()), 7.0, ["Physical", "Projectile", "Minion", "Bleed"], "Blood Orb", 0.95)
				else:
					spawn_projectile(m["pos"], dir * 500.0, scaled_damage(8.0, ["Physical", "Projectile", "Minion"], get_stats()), 6.0, ["Physical", "Projectile", "Minion"], "Bone Wisp", 1.1)
				m["cd"] = 0.65

func deal_damage(e: Dictionary, raw_damage: float, tags: Array, source_pos: Vector2, source_name: String) -> void:
	if e["hp"] <= 0.0:
		return
	var stats := get_stats()
	var damage := raw_damage
	if has_flag(stats, "execute_low_hp") and e["hp"] / e["max_hp"] <= 0.25:
		damage *= 1.28
	if e["statuses"].has("shock"):
		damage *= 1.16
	if e["statuses"].has("curse"):
		damage *= 1.12 + (0.08 if has_flag(stats, "curse_amp") else 0.0)
	if has_flag(stats, "poison_projectile_payoff") and e["statuses"].has("poison") and has_tag(tags, "Projectile"):
		damage *= 1.22
	if has_flag(stats, "bleed_payoff") and e["statuses"].has("bleed") and has_tag(tags, "Melee"):
		damage *= 1.20
	var crit: bool = rng.randf() < stats["crit_chance"]
	if crit:
		damage *= stats["crit_mult"]
	e["hp"] -= damage
	floating(("CRIT " if crit else "") + str(int(damage)), e["pos"] + Vector2(rng.randf_range(-14, 14), -34), Color(1.0, 0.93, 0.62) if crit else Color(0.93, 0.9, 0.78))
	apply_on_hit_statuses(e, damage, tags, stats)
	if has_flag(stats, "frostfire_steam") and has_tag(tags, "Fire") and e["statuses"].has("freeze"):
		e["statuses"].erase("freeze")
		spawn_explosion(e["pos"], 145.0 if has_flag(stats, "steam_big") else 105.0, damage * (1.08 if has_flag(stats, "steam_big") else 0.86), ["Steam", "Area", "Spell"], "FROSTFIRE")
		floating("steam burst", e["pos"] + Vector2(0, -56), Color(0.75, 0.95, 1.0))
	if has_flag(stats, "shatter_lightning") and has_tag(tags, "Lightning") and e["statuses"].has("freeze"):
		e["statuses"].erase("freeze")
		spawn_explosion(e["pos"], 78.0, damage * 0.72, ["Cold", "Area", "Shatter"], "SHATTER")
		floating("shatter", e["pos"] + Vector2(0, -56), Color(0.62, 0.9, 1.0))
	if has_flag(stats, "burn_consume") and has_tag(tags, "Fire") and e["statuses"].has("burn"):
		var burn = e["statuses"]["burn"]
		e["hp"] -= float(burn.get("dps", 0.0)) * 1.2
		e["statuses"].erase("burn")
		floating("burn paid", e["pos"] + Vector2(0, -62), Color(1.0, 0.44, 0.18))
	if e["hp"] <= 0.0:
		on_enemy_death(e)
		enemies.erase(e)

func apply_on_hit_statuses(e: Dictionary, damage: float, tags: Array, stats: Dictionary) -> void:
	if has_tag(tags, "Burn") or has_tag(tags, "Fire"):
		apply_status(e, "burn", 2.8 + stats.get("burn_duration", 0.0), damage * 0.20 * stats["burn_power"])
	if has_tag(tags, "Freeze") or has_tag(tags, "Cold"):
		apply_status(e, "freeze", 1.10 + stats.get("freeze_duration", 0.0), 0.0)
	if has_tag(tags, "Slash") and has_flag(stats, "slash_bleed"):
		apply_status(e, "bleed", 3.8, damage * 0.18)
	if has_tag(tags, "Lightning"):
		apply_status(e, "shock", 2.5, 0.0)
	if has_tag(tags, "Poison") or (has_tag(tags, "Trap") and has_flag(stats, "trap_poison")):
		apply_status(e, "poison", 3.4 + stats.get("poison_duration", 0.0), damage * 0.16 * stats["poison_damage"])
	if has_tag(tags, "Curse") or has_tag(tags, "Void"):
		apply_status(e, "curse", 4.0, 0.0)

func apply_status(e: Dictionary, name: String, time: float, dps: float) -> void:
	var statuses: Dictionary = e["statuses"]
	if statuses.has(name):
		statuses[name]["time"] = max(float(statuses[name]["time"]), time)
		statuses[name]["dps"] = max(float(statuses[name].get("dps", 0.0)), dps)
	else:
		statuses[name] = {"time": time, "dps": dps}

func on_enemy_death(e: Dictionary) -> void:
	if e.get("dead", false):
		return
	e["dead"] = true
	var stats := get_stats()
	kills += 1
	xp += float(ENEMY_TYPES[e["type"]]["xp"])
	gold += rng.randi_range(2, 7)
	floating("dead", e["pos"] + Vector2(0, -40), Color(0.8, 0.8, 0.8))
	if has_flag(stats, "kill_momentum") and kills % 5 == 0:
		focus_time = 1.8 + stats.get("focus_duration", 0.0)
		for s in skill_cd.keys():
			skill_cd[s] = max(0.0, float(skill_cd[s]) - 0.25)
		floating("momentum", player_pos + Vector2(0, -72), Color(1.0, 0.93, 0.35))
	if has_flag(stats, "burn_death_explode") and e["statuses"].has("burn"):
		spawn_explosion(e["pos"], 88.0, 19.0 + level * 3.0, ["Fire", "Area", "Burn"], "burn death")
	if has_flag(stats, "curse_death_burst") and e["statuses"].has("curse"):
		spawn_explosion(e["pos"], 94.0, 18.0 + level * 3.2, ["Void", "Area", "Curse"], "curse debt")
	if has_flag(stats, "curse_mana_refund") and e["statuses"].has("curse"):
		player_mana = min(stats["max_mana"], player_mana + 9.0)
	if has_flag(stats, "corpse_spark"):
		var n := nearest_enemy(e["pos"], 360.0)
		if n != null:
			deal_damage(n, scaled_damage(16.0 + level * 2.0, ["Lightning", "Spell"], stats), ["Lightning", "Spell", "Chain"], e["pos"], "corpse spark")
	if has_flag(stats, "bone_wisp_on_kill") and rng.randf() < 0.45:
		minions.append({"pos": player_pos, "life": 12.0, "cd": 0.2, "angle": rng.randf() * TAU})
		floating("wisp", e["pos"] + Vector2(0, -54), Color(0.66, 0.88, 1.0))
	if rng.randf() < 0.22 or e["type"] == "Vault Warden":
		_drop_item(e["pos"], false)
	while xp >= xp_to_next:
		xp -= xp_to_next
		level += 1
		xp_to_next *= 1.28
		passive_points += 1
		start_passive_choice()

func player_take_damage(amount: float, source_pos: Vector2) -> void:
	if guard_time > 0.0:
		amount *= 0.45
		guard_time = 0.0
		floating("guarded", player_pos + Vector2(0, -44), Color(0.8, 0.9, 1.0))
	if invuln_time > 0.0:
		floating("evade", player_pos + Vector2(0, -32), Color(0.8, 0.9, 1.0))
		return
	player_hp -= amount
	invuln_time = 0.22
	floating("-" + str(int(amount)), player_pos + Vector2(0, -34), Color(1.0, 0.25, 0.18))
	if player_hp <= 0.0:
		player_hp = 0.0
		run_state = "game_over"
		choice_mode = "end"
		choice_label.text = "RUN FAILED\n\nYou died in room " + str(room_index) + ".\n\nPress R to restart."
		log_msg("Run failed. Press R to restart.")

func start_passive_choice() -> void:
	choice_mode = "passive"
	passive_choices.clear()
	var available := []
	for p in PASSIVE_POOL:
		if not owned_passives.has(p["id"]):
			available.append(p)
	available.shuffle()
	for i in range(min(3, available.size())):
		passive_choices.append(available[i])
	log_msg("Passive point available: choose a node with 1/2/3. Points left: " + str(passive_points))

func choose_active_option(idx: int) -> void:
	if choice_mode == "skill_draft":
		choose_skill_draft(idx)
	elif choice_mode == "passive":
		if idx >= passive_choices.size(): return
		var p = passive_choices[idx]
		owned_passives.append(p["id"])
		passive_points = max(0, passive_points - 1)
		log_msg("Passive acquired: " + p["name"])
		if passive_points > 0:
			start_passive_choice()
			return
		if passive_returns_to_route:
			passive_returns_to_route = false
			choice_mode = "route"
			passive_choices.clear()
			make_route_choices()
		else:
			choice_mode = ""
			passive_choices.clear()
	elif choice_mode == "reward":
		if idx >= reward_choices.size(): return
		var choice = reward_choices[idx]
		apply_reward_choice(choice)
		if choice_mode == "":
			choice_mode = "route"
			make_route_choices()
	elif choice_mode == "route":
		if idx >= route_choices.size(): return
		var route = route_choices[idx]
		room_index += 1
		run_depth += 1
		choice_mode = ""
		run_state = "combat"
		spawn_room_from_route(route)

func make_skill_draft_choices() -> void:
	skill_draft_choices.clear()
	var available := []
	for s in all_skill_names:
		if not active_skills.has(s):
			available.append(s)
	available.shuffle()
	for i in range(min(4, available.size())):
		skill_draft_choices.append(available[i])
	if skill_draft_choices.size() == 0:
		var fallback := get_selected_skill_name()
		if fallback != "":
			skill_points[fallback] = int(skill_points.get(fallback, 0)) + 1
		choice_mode = "route" if skill_draft_returns_to_route else ""
		if choice_mode == "route": make_route_choices()

func choose_skill_draft(idx: int) -> void:
	if idx < 0 or idx >= skill_draft_choices.size(): return
	var s = str(skill_draft_choices[idx])
	if not active_skills.has(s):
		active_skills.append(s)
		selected_skill = active_skills.size() - 1
		skill_points[s] = int(skill_points.get(s, 0)) + 1
		log_msg("Skill learned: " + s + " (+1 skill point).")
	starter_picks_remaining = max(0, starter_picks_remaining - 1)
	if starter_picks_remaining > 0:
		make_skill_draft_choices()
		return
	if skill_draft_returns_to_route:
		skill_draft_returns_to_route = false
		choice_mode = "route"
		make_route_choices()
	else:
		choice_mode = ""
		run_state = "combat"
		spawn_room(false)

func apply_reward_choice(choice: Dictionary) -> void:
	match choice["type"]:
		"item":
			_drop_item(player_pos + Vector2(-55, -55), true)
			_drop_item(player_pos + Vector2(0, -70), true)
			_drop_item(player_pos + Vector2(55, -55), false)
			log_msg("Reward: three-item cache dropped near you.")
		"passive":
			passive_points += 1
			passive_returns_to_route = true
			start_passive_choice()
			return
		"forge":
			var stats := get_stats()
			player_hp = min(stats["max_hp"], player_hp + 44.0)
			player_mana = min(stats["max_mana"], player_mana + 70.0)
			if rng.randf() < 0.35:
				_drop_item(player_pos + Vector2(0, -65), true)
			log_msg("Forge reward: restored health/mana and may add gear.")
		"skill":
			var skill_name := get_selected_skill_name()
			if skill_name == "":
				starter_picks_remaining = 1
				skill_draft_returns_to_route = true
				choice_mode = "skill_draft"
				make_skill_draft_choices()
				return
			skill_points[skill_name] = int(skill_points.get(skill_name, 0)) + 1
			if has_flag(get_stats(), "study_bonus"):
				gain_skill_xp(skill_name, 40.0)
			open_panel = "skilltree"
			build_panel_visible = true
			log_msg("Skill reward: +1 point for " + skill_name + ". Press K, then 1-9 to unlock.")
		"skill_draft":
			starter_picks_remaining = 1
			skill_draft_returns_to_route = true
			choice_mode = "skill_draft"
			make_skill_draft_choices()
			return
		"respec":
			respec_all_trees()
			return
	choice_mode = ""

func _check_room_clear() -> void:
	if enemies.size() == 0 and run_state == "combat":
		rooms_cleared += 1
		if current_room.get("type", "Combat") == "Boss":
			run_state = "victory"
			choice_mode = "end"
			choice_label.text = "VAULT CLEARED\n\nYou defeated the Patch 003 long-form contract route.\n\nPress R to restart and test another build."
			log_msg("Victory. Try restarting with a different build route.")
		else:
			run_state = "reward"
			choice_mode = "reward"
			if rooms_cleared - last_room_rewarded_skill_point >= 2 and active_skills.size() > 0:
				last_room_rewarded_skill_point = rooms_cleared
				var skill_name := get_selected_skill_name()
				skill_points[skill_name] = int(skill_points.get(skill_name, 0)) + 1
				log_msg("Dungeon mastery: +1 " + skill_name + " skill point. Press K to spend it.")
			make_reward_choices()
			log_msg("Room cleared. Choose a reward.")

func make_reward_choices() -> void:
	reward_choices = [
		{"type":"item", "name":"Item Cache", "desc":"Drop three equipment pieces. Best for finding build-defining effects."},
		{"type":"skill", "name":"Skill Study", "desc":"Gain +1 point for your selected skill tree. Press K to spend it."},
		{"type":"passive", "name":"Passive Shrine", "desc":"Gain and spend a passive point. Good for steering archetypes."}
	]
	var fourth := rng.randi_range(0, 3)
	if fourth == 0:
		reward_choices.append({"type":"skill_draft", "name":"Skill Draft", "desc":"Learn a new active skill, or widen your chain engine."})
	elif fourth == 1:
		reward_choices.append({"type":"forge", "name":"Forge Patch", "desc":"Restore health/mana and maybe drop gear."})
	elif fourth == 2:
		reward_choices.append({"type":"respec", "name":"Respec Font", "desc":"Refund all passive and skill-tree nodes. Prototype QoL: no cost."})
	else:
		reward_choices.append({"type":"item", "name":"Greedy Cache", "desc":"More gear. The buildcraft answer is often another strange item."})

func make_route_choices() -> void:
	route_choices.clear()
	if run_depth >= max_depth - 1:
		route_choices = [{"name":"Boss Door", "type":"Boss", "biome":"Void Reliquary", "desc":"Fight the Vault Warden. Clear it to win the contract.", "elite":true, "treasure":false, "mods":["Curse Pressure", "Boss Arena"], "threat":1.55}]
		return
	var types := ["Combat", "Elite", "Treasure", "Shrine", "Forge", "Skill Trial", "Reliquary", "Gauntlet", "Library"]
	var biomes := ROOM_BIOMES.keys()
	for i in range(3):
		var t = types[rng.randi_range(0, types.size() - 1)]
		if run_depth < 2 and (t == "Skill Trial" or t == "Gauntlet"):
			t = "Combat"
		var b = biomes[rng.randi_range(0, biomes.size() - 1)]
		var mods := []
		var biome_data = ROOM_BIOMES[b]
		mods.append(biome_data["mods"][rng.randi_range(0, biome_data["mods"].size() - 1)])
		if rng.randf() < 0.45 + float(run_depth) * 0.03:
			mods.append(random_contract_mod())
		var threat := 1.0 + run_depth * 0.08
		if t == "Elite": threat += 0.32
		if t == "Treasure" or t == "Library": threat -= 0.10
		if t == "Gauntlet": threat += 0.22
		route_choices.append({"name": b + " - " + t, "type":t, "biome":b, "desc": room_desc(t, mods), "elite":t == "Elite", "treasure":t == "Treasure", "mods":mods, "threat":threat})

func spawn_room(elite := false, treasure := false) -> void:
	var route := {"name":"Ash Crypt - Combat", "type":"Combat", "biome":"Ash Crypt", "desc":"Starter contract room.", "elite":elite, "treasure":treasure, "mods":[], "threat":1.0}
	spawn_room_from_route(route)

func spawn_room_from_route(route: Dictionary) -> void:
	current_room = route.duplicate(true)
	enemies.clear()
	projectiles.clear()
	enemy_projectiles.clear()
	zones.clear()
	obstacles.clear()
	traps.clear()
	chests.clear()
	room_decor.clear()
	generate_room_layout(route)
	var room_type := str(route.get("type", "Combat"))
	if room_type == "Boss":
		spawn_enemy("Vault Warden", WORLD_CENTER + Vector2(220, 0))
		spawn_enemy("Mirror Acolyte", WORLD_CENTER + Vector2(-260, -130))
		spawn_enemy("Oathless Knight", WORLD_CENTER + Vector2(-260, 130))
		log_msg("Boss room: Vault Warden spawned in " + str(route.get("biome", "Void Reliquary")) + ".")
		return
	var count := 3 + room_index + int(run_depth * 0.6)
	if route.get("elite", false): count += 4
	if room_type == "Treasure": count = max(2, count - 2)
	if room_type == "Shrine": count = max(2, count - 3)
	if room_type == "Forge": count = max(2, count - 2)
	if room_type == "Skill Trial": count += 2
	if room_type == "Gauntlet": count += 5
	if room_type == "Library": count = max(2, count - 2)
	if room_type == "Reliquary": count += 1
	for i in range(count):
		var types := enemy_pool_for_room(route)
		spawn_enemy(types[rng.randi_range(0, types.size() - 1)], random_spawn_pos())
	if route.get("treasure", false) or room_type == "Treasure":
		spawn_chest(WORLD_CENTER + Vector2(0, -90), true)
	if room_type == "Library":
		spawn_chest(WORLD_CENTER + Vector2(0, -90), true)
		var s_lib := get_selected_skill_name()
		if s_lib != "":
			skill_points[s_lib] = int(skill_points.get(s_lib, 0)) + 1
			log_msg("Library room: +1 " + s_lib + " skill point.")
	if room_type == "Reliquary":
		_drop_item(WORLD_CENTER + Vector2(-42, -82), true)
		_drop_item(WORLD_CENTER + Vector2(42, -82), true)
	if room_type == "Forge":
		spawn_chest(WORLD_CENTER + Vector2(-65, -85), true)
		spawn_chest(WORLD_CENTER + Vector2(65, -85), false)
	if room_type == "Shrine":
		zones.append({"pos": WORLD_CENTER + Vector2(0, -105), "radius": 58.0, "time": 0.25, "duration": 999.0, "visual": "shrine", "color": Color(1.0, 0.86, 0.35, 0.17)})
	if room_type == "Skill Trial" and active_skills.size() > 0:
		var skill_name := get_selected_skill_name()
		skill_points[skill_name] = int(skill_points.get(skill_name, 0)) + 1
		log_msg("Skill Trial started: +1 " + skill_name + " point granted upfront.")
	log_msg("Room " + str(room_index) + ": " + str(route.get("name", room_type)) + " | Mods: " + ", ".join(route.get("mods", [])) + ".")

func spawn_enemy(type_name: String, pos: Vector2) -> void:
	var data = ENEMY_TYPES[type_name]
	enemies.append({
		"id": rng.randi(), "type": type_name, "pos": clamp_to_arena(pos, float(data["radius"])),
		"hp": float(data["hp"]) * (1.0 + room_index * 0.08), "max_hp": float(data["hp"]) * (1.0 + room_index * 0.08),
		"radius": float(data["radius"]), "ai_cd": rng.randf_range(0.2, 1.2), "statuses": {},
		"charge_time": 0.0, "charge_vel": Vector2.ZERO, "dead": false
	})

func random_spawn_pos() -> Vector2:
	var side := rng.randi_range(0, 3)
	match side:
		0: return Vector2(rng.randf_range(ARENA.position.x + 40, ARENA.end.x - 40), ARENA.position.y + 35)
		1: return Vector2(rng.randf_range(ARENA.position.x + 40, ARENA.end.x - 40), ARENA.end.y - 35)
		2: return Vector2(ARENA.position.x + 35, rng.randf_range(ARENA.position.y + 40, ARENA.end.y - 40))
		_: return Vector2(ARENA.end.x - 35, rng.randf_range(ARENA.position.y + 40, ARENA.end.y - 40))

func _drop_item(pos: Vector2, force_good: bool) -> void:
	var pool := ITEM_POOL.duplicate(true)
	if not force_good and rng.randf() < 0.45:
		# Prefer non-legendary drops in normal rooms so legendaries still feel like spikes.
		var reduced := []
		for item in pool:
			if item["rarity"] != "Legendary":
				reduced.append(item)
		pool = reduced
	var item = pool[rng.randi_range(1, pool.size() - 1)].duplicate(true)
	# Add a small random affix to non-starter drops.
	var affixes := [
		{"text":"of Heat", "stats":{"fire_damage":0.06}},
		{"text":"of Speed", "stats":{"move_speed":10.0}},
		{"text":"of Focus", "stats":{"crit_chance":0.03}},
		{"text":"of Flow", "stats":{"cooldown_reduction":0.03}},
		{"text":"of Sparks", "stats":{"lightning_damage":0.06}},
		{"text":"of Winter", "stats":{"cold_damage":0.06}}
	]
	if rng.randf() < 0.62:
		var a = affixes[rng.randi_range(0, affixes.size() - 1)]
		item["name"] = item["name"] + " " + a["text"]
		for k in a["stats"].keys():
			item["stats"][k] = item["stats"].get(k, 0.0) + a["stats"][k]
	loot.append({"pos": clamp_to_arena(pos, 12.0), "item": item, "bob": rng.randf() * TAU})

func _update_loot_tracking() -> void:
	nearest_loot_index = -1
	var best := 99999.0
	for i in range(loot.size()):
		var d = player_pos.distance_to(loot[i]["pos"])
		if d < best and d <= 76.0:
			best = d
			nearest_loot_index = i

func equip_nearest_loot() -> void:
	if nearest_loot_index < 0:
		return
	var item = loot[nearest_loot_index]["item"]
	var slot := str(item["slot"])
	if slot == "ring":
		if equipped["ring1"] == null:
			equipped["ring1"] = item
		elif equipped["ring2"] == null:
			equipped["ring2"] = item
		else:
			equipped["ring1"] = item
	else:
		equipped[slot] = item
	loot.remove_at(nearest_loot_index)
	log_msg("Equipped: " + item["name"] + " [" + item["slot"] + "]")
	var stats := get_stats()
	player_hp = min(player_hp, stats["max_hp"])
	player_mana = min(player_mana, stats["max_mana"])

func get_stats() -> Dictionary:
	var stats := {
		"max_hp": 120.0, "max_mana": 100.0, "mana_regen": 17.0, "move_speed": 250.0,
		"global_damage": 1.0, "spell_damage": 1.0, "melee_damage": 1.0, "projectile_damage": 1.0,
		"fire_damage": 1.0, "cold_damage": 1.0, "lightning_damage": 1.0, "physical_damage": 1.0,
		"void_damage": 1.0, "poison_damage": 1.0, "trap_damage": 1.0, "minion_damage": 1.0,
		"burn_power": 1.0, "burn_duration": 0.0, "freeze_duration": 0.0, "poison_duration": 0.0, "trap_radius": 0.0,
		"cooldown_reduction": 0.0, "projectile_count": 1, "crit_chance": 0.06, "crit_mult": 1.55,
		"dash_recovery": 0.0, "focus_duration": 0.0, "flags": {}
	}
	for slot in equipped.keys():
		var item = equipped[slot]
		if item != null:
			merge_item_stats(stats, item)
	for p in PASSIVE_POOL:
		if owned_passives.has(p["id"]):
			merge_item_stats(stats, p)
	for skill_name in owned_skill_nodes.keys():
		for node_id in owned_skill_nodes[skill_name]:
			var node := find_skill_node(skill_name, node_id)
			if node != null:
				merge_item_stats(stats, node)
	if has_flag(stats, "contract_eater"):
		stats["global_damage"] += 0.025 * float(current_room.get("mods", []).size())
	if has_flag(stats, "depth_scaling"):
		stats["global_damage"] += 0.025 * float(run_depth)
	stats["max_hp"] = max(45.0, stats["max_hp"])
	stats["max_mana"] = max(25.0, stats["max_mana"])
	stats["cooldown_reduction"] = clamp(stats["cooldown_reduction"], -0.3, 0.65)
	stats["crit_chance"] = clamp(stats["crit_chance"], 0.0, 0.75)
	return stats

func merge_item_stats(stats: Dictionary, item: Dictionary) -> void:
	var mods: Dictionary = item.get("stats", {})
	for k in mods.keys():
		if k == "projectile_count":
			stats[k] = int(stats.get(k, 1)) + int(mods[k])
		else:
			stats[k] = float(stats.get(k, 0.0)) + float(mods[k])
	for f in item.get("flags", []):
		stats["flags"][f] = true

func has_flag(stats: Dictionary, flag: String) -> bool:
	return stats.get("flags", {}).has(flag)

func scaled_damage(base: float, tags: Array, stats: Dictionary) -> float:
	var d = base * stats["global_damage"]
	if has_tag(tags, "Spell"): d *= stats["spell_damage"]
	if has_tag(tags, "Melee"): d *= stats["melee_damage"]
	if has_tag(tags, "Projectile"): d *= stats["projectile_damage"]
	if has_tag(tags, "Fire"): d *= stats["fire_damage"]
	if has_tag(tags, "Cold"): d *= stats["cold_damage"]
	if has_tag(tags, "Lightning"): d *= stats["lightning_damage"]
	if has_tag(tags, "Void") or has_tag(tags, "Curse"): d *= stats["void_damage"]
	if has_tag(tags, "Poison"): d *= stats["poison_damage"]
	if has_tag(tags, "Trap"): d *= stats["trap_damage"]
	if has_tag(tags, "Minion"): d *= stats["minion_damage"]
	if has_tag(tags, "Physical") or has_tag(tags, "Slash"): d *= stats["physical_damage"]
	return max(1.0, d)

func chain_lightning(first_enemy: Dictionary, damage: float, stats: Dictionary) -> void:
	var chains := 1
	if has_flag(stats, "chain_plus"):
		chains += 1
	var current := first_enemy
	var hit := {first_enemy["id"]: true}
	for i in range(chains):
		var next := nearest_enemy(current["pos"], 260.0, hit)
		if next == null:
			return
		hit[next["id"]] = true
		deal_damage(next, damage * pow(0.72, i), ["Lightning", "Spell", "Chain"], current["pos"], "chain")
		zones.append({"pos": (current["pos"] + next["pos"]) * 0.5, "radius": 18.0, "time": 0.08, "duration": 0.14, "visual": "chain", "color": Color(0.45, 0.72, 1.0, 0.42)})
		current = next

func nearest_enemy(from_pos: Vector2, max_dist: float, ignored := {}) -> Variant:
	var best = null
	var best_d := max_dist
	for e in enemies:
		if ignored.has(e["id"]):
			continue
		var d = from_pos.distance_to(e["pos"])
		if d < best_d:
			best_d = d
			best = e
	return best

func check_perfect_dodge_focus(stats: Dictionary) -> void:
	if not has_flag(stats, "perfect_dodge_focus"):
		return
	for e in enemies:
		if player_pos.distance_to(e["pos"]) < e["radius"] + player_radius + 28.0:
			focus_time = 2.0 + stats.get("focus_duration", 0.0)
			if has_flag(stats, "lance_dodge_reload"):
				skill_cd["Storm Lance"] = max(0.0, skill_cd.get("Storm Lance", 0.0) - 0.55)
			floating("perfect dodge", player_pos + Vector2(0, -50), Color(0.92, 0.94, 1.0))
			return

func log_msg(t: String) -> void:
	message_log.push_front(t)
	while message_log.size() > 5:
		message_log.pop_back()

func floating(t: String, pos: Vector2, color: Color) -> void:
	floating_text.append({"text": t, "pos": pos, "life": 0.75, "color": color})

func _update_floating_text(delta: float) -> void:
	for i in range(floating_text.size() - 1, -1, -1):
		floating_text[i]["life"] -= delta
		floating_text[i]["pos"].y -= 24.0 * delta
		if floating_text[i]["life"] <= 0.0:
			floating_text.remove_at(i)

func _update_ui() -> void:
	var stats := get_stats()
	var skill_lines := []
	for i in range(active_skills.size()):
		var s = active_skills[i]
		var mark := "> " if i == selected_skill else "  "
		skill_lines.append(mark + str(i + 1) + ": " + s + " cd " + str(snapped(skill_cd.get(s, 0.0), 0.1)))
	if active_skills.size() == 0:
		skill_lines.append("No skills yet: choose a Skill Draft.")
	hud_label.text = "HP " + str(int(player_hp)) + "/" + str(int(stats["max_hp"])) + "   Mana " + str(int(player_mana)) + "/" + str(int(stats["max_mana"])) + "   Lv " + str(level) + " XP " + str(int(xp)) + "/" + str(int(xp_to_next)) + "   Gold " + str(gold) + "\n" + \
		"Room " + str(room_index) + "   Kills " + str(kills) + "   Dash " + str(snapped(dash_cooldown, 0.1)) + ("   FOCUS" if focus_time > 0.0 else "") + "\n" + \
		"\n".join(skill_lines)

	build_label.visible = build_panel_visible
	if build_panel_visible:
		build_label.text = panel_text(stats)
	log_label.text = "\n".join(message_log)
	if nearest_loot_index >= 0:
		var item = loot[nearest_loot_index]["item"]
		loot_label.text = "E pick up: " + item["name"] + " [" + item["rarity"] + " " + item["slot"] + "] - " + item["desc"]
	else:
		loot_label.text = ""
	choice_label.text = choice_text()

func build_text(stats: Dictionary) -> String:
	var text := "BUILD PANEL\n"
	text += "Damage x" + str(snapped(stats["global_damage"], 0.01)) + " | CDR " + str(int(stats["cooldown_reduction"] * 100.0)) + "% | Crit " + str(int(stats["crit_chance"] * 100.0)) + "%\n"
	text += "Proj " + str(stats["projectile_count"]) + " | Fire " + str(snapped(stats["fire_damage"], 0.01)) + " | Cold " + str(snapped(stats["cold_damage"], 0.01)) + " | Lightning " + str(snapped(stats["lightning_damage"], 0.01)) + "\n\n"
	text += "EQUIPMENT\n"
	for slot in equipped.keys():
		var item = equipped[slot]
		text += slot + ": " + (item["name"] if item != null else "-") + "\n"
	text += "\nFLAGS\n"
	var flags = stats["flags"].keys()
	text += (", ".join(flags) if flags.size() > 0 else "none") + "\n\n"
	text += "ROOM: " + str(current_room.get("type", "Combat")) + " / " + str(current_room.get("biome", "Ash Crypt")) + "\n"
	text += "PASSIVES\n"
	if owned_passives.size() == 0:
		text += "none\n"
	else:
		for p in PASSIVE_POOL:
			if owned_passives.has(p["id"]):
				text += "- " + p["name"] + "\n"
	return text

func choice_text() -> String:
	if choice_mode == "skill_draft":
		var sd := "SKILL DRAFT"
		if starter_picks_remaining > 0:
			sd += " - choose " + str(starter_picks_remaining) + " more"
		sd += "\n\nStart narrow. Pick 1-2 skills you actually want to build around; later rewards can add more.\n\n"
		for i in range(skill_draft_choices.size()):
			var s = str(skill_draft_choices[i])
			var d = SKILLS[s]
			sd += str(i + 1) + ") " + s + "\n" + str(d.get("desc", "")) + "\nTags: " + ", ".join(d.get("tags", [])) + "\n\n"
		return sd
	if choice_mode == "passive":
		var t = "CHOOSE PASSIVE  |  Points left: " + str(passive_points) + "\n\n"
		for i in range(passive_choices.size()):
			var p = passive_choices[i]
			t += str(i + 1) + ") " + p["name"] + "\n" + p["desc"] + "\n\n"
		return t
	elif choice_mode == "reward":
		var tr := "ROOM CLEARED: CHOOSE REWARD\n\n"
		for i in range(reward_choices.size()):
			var c = reward_choices[i]
			tr += str(i + 1) + ") " + c["name"] + "\n" + c["desc"] + "\n\n"
		return tr
	elif choice_mode == "route":
		var rr := "CHOOSE NEXT ROOM\n\n"
		for i in range(route_choices.size()):
			var c2 = route_choices[i]
			rr += str(i + 1) + ") " + c2["name"] + "\n" + c2["desc"] + "\n\n"
		return rr
	elif choice_mode == "end":
		return choice_label.text
	return ""

func _draw() -> void:
	# Arena background and grid
	draw_rect(Rect2(Vector2.ZERO, Vector2(1280, 720)), Color(0.075, 0.068, 0.09))
	draw_rect(ARENA, Color(0.13, 0.115, 0.145), true)
	draw_rect(ARENA, Color(0.42, 0.32, 0.20), false, 3.0)
	for x in range(int(ARENA.position.x), int(ARENA.end.x), 48):
		draw_line(Vector2(x, ARENA.position.y), Vector2(x, ARENA.end.y), Color(0.19, 0.17, 0.20, 0.6), 1.0)
	for y in range(int(ARENA.position.y), int(ARENA.end.y), 48):
		draw_line(Vector2(ARENA.position.x, y), Vector2(ARENA.end.x, y), Color(0.19, 0.17, 0.20, 0.6), 1.0)

	for ob in obstacles:
		draw_rect(ob["rect"], ob.get("color", Color(0.23, 0.20, 0.18)), true)
		draw_rect(ob["rect"], Color(0.05, 0.04, 0.035), false, 2.0)
	for tr in traps:
		var tc: Color = tr.get("color", Color(0.8, 0.2, 0.15, 0.22))
		draw_circle(tr["pos"], tr["radius"], Color(tc.r, tc.g, tc.b, 0.18 if tr.get("armed", true) else 0.08))
		draw_arc(tr["pos"], tr["radius"], 0, TAU, 32, Color(tc.r, tc.g, tc.b, 0.7), 2.0)
	for ch in chests:
		var cp: Vector2 = ch["pos"]
		var cc := Color(1.0, 0.78, 0.25) if ch.get("good", false) else Color(0.62, 0.48, 0.28)
		draw_rect(Rect2(cp - Vector2(15, 10), Vector2(30, 20)), cc, true)
		draw_rect(Rect2(cp - Vector2(15, 10), Vector2(30, 20)), Color(0.08, 0.05, 0.02), false, 2.0)

	for z in zones:
		var c: Color = z.get("color", Color(1,1,1,0.2))
		draw_circle(z["pos"], z["radius"], c)
		draw_arc(z["pos"], z["radius"], 0, TAU, 48, Color(c.r, c.g, c.b, 0.65), 2.0)

	for l in loot:
		var item = l["item"]
		var c2 := rarity_color(item["rarity"])
		var p: Vector2 = l["pos"]
		draw_colored_polygon([p + Vector2(0, -11), p + Vector2(11, 0), p + Vector2(0, 11), p + Vector2(-11, 0)], c2)
		draw_circle(p, 16.0, Color(c2.r, c2.g, c2.b, 0.16))

	for p2 in projectiles:
		var pc := zone_color(p2["tags"])
		draw_circle(p2["pos"], p2["radius"], Color(pc.r, pc.g, pc.b, 0.92))
		draw_circle(p2["pos"], p2["radius"] + 5.0, Color(pc.r, pc.g, pc.b, 0.20))
	for ep in enemy_projectiles:
		draw_circle(ep["pos"], ep["radius"], ep["color"])
		draw_circle(ep["pos"], ep["radius"] + 4.0, Color(ep["color"].r, ep["color"].g, ep["color"].b, 0.18))

	for m in minions:
		var mc := Color(1.0, 0.15, 0.20) if str(m.get("kind", "bone")) == "blood" else Color(0.63, 0.88, 1.0)
		draw_circle(m["pos"], 8.0, mc)
		draw_circle(m["pos"], 14.0, Color(mc.r, mc.g, mc.b, 0.16))

	for e in enemies:
		var data = ENEMY_TYPES[e["type"]]
		var c3: Color = data["color"]
		if e["statuses"].has("freeze"):
			c3 = Color(0.55, 0.85, 1.0)
		draw_circle(e["pos"], e["radius"], c3)
		draw_arc(e["pos"], e["radius"] + 2.0, 0, TAU, 30, Color(0.05, 0.04, 0.05), 2.0)
		var hp_w: float = e["radius"] * 2.2
		var hp_pct := clamp(e["hp"] / e["max_hp"], 0.0, 1.0)
		draw_rect(Rect2(e["pos"] + Vector2(-hp_w * 0.5, -e["radius"] - 14), Vector2(hp_w, 4)), Color(0.12, 0.05, 0.05), true)
		draw_rect(Rect2(e["pos"] + Vector2(-hp_w * 0.5, -e["radius"] - 14), Vector2(hp_w * hp_pct, 4)), Color(0.86, 0.12, 0.10), true)
		_draw_status_pips(e)

	# Player
	var aim := aim_dir()
	var pc_player := Color(0.38, 0.72, 1.0) if invuln_time <= 0.0 else Color(0.82, 0.92, 1.0)
	draw_circle(player_pos, player_radius, pc_player)
	draw_circle(player_pos, player_radius + 5.0, Color(pc_player.r, pc_player.g, pc_player.b, 0.17))
	draw_line(player_pos, player_pos + aim * 38.0, Color(1.0, 0.94, 0.55), 3.0)
	if focus_time > 0.0:
		draw_arc(player_pos, 28.0, 0, TAU, 48, Color(1.0, 0.93, 0.24, 0.9), 2.0)

	# Floating text uses default theme font.
	var font := ThemeDB.get_fallback_font()
	for ft in floating_text:
		var alpha := clamp(float(ft["life"]) / 0.75, 0.0, 1.0)
		var col: Color = ft["color"]
		col.a = alpha
		draw_string(font, ft["pos"], ft["text"], HORIZONTAL_ALIGNMENT_CENTER, 120, 14, col)


func panel_text(stats: Dictionary) -> String:
	match open_panel:
		"inventory": return inventory_text(stats)
		"skilltree": return skill_tree_text(stats)
		"dungeon": return dungeon_text(stats)
		"guide": return guide_text(stats)
		_: return build_text(stats)

func get_selected_skill_name() -> String:
	if active_skills.size() == 0:
		return ""
	selected_skill = int(clamp(selected_skill, 0, active_skills.size() - 1))
	return str(active_skills[selected_skill])

func respec_all_trees() -> void:
	if run_state == "reward":
		passive_returns_to_route = true
	var refunded_passives := owned_passives.size()
	passive_points += refunded_passives
	owned_passives.clear()
	for s in owned_skill_nodes.keys():
		var refund: int = owned_skill_nodes[s].size()
		skill_points[s] = int(skill_points.get(s, 0)) + refund
		owned_skill_nodes[s].clear()
	open_panel = "guide"
	build_panel_visible = true
	log_msg("Respec complete: refunded " + str(refunded_passives) + " passive nodes and all skill-tree nodes. Press K/G/P as needed.")
	if passive_points > 0:
		start_passive_choice()

func guide_text(stats: Dictionary) -> String:
	var t = "PATCH 003 GUIDE / CLEANUP NOTES\n"
	t += "Run goal: start almost empty, draft 2 skills, then push 1-2 favorites into absurd chain builds over a 16-depth contract.\n\n"
	t += "Core loop: clear room -> choose reward -> choose next route. A full tuned run target is 20-30 minutes.\n\n"
	t += "Build engine: skills have tags. Items, passives, and skill nodes add flags. Flags create chains like Fireball -> Storm Lance -> Frost Nova -> Fireball, or Rift -> Trap -> Fireball.\n\n"
	t += "QoL: O refunds passives/skill nodes. K opens skill tree. I equips inventory. G opens this guide. F drops test gear.\n\n"
	t += "Good test builds:\n"
	t += "1. Frostfire: Frost Nova + Fireball + Frostfire/Steam nodes.\n"
	t += "2. Cascade Mage: Fireball + Storm Lance + Cascade/Fivefold nodes.\n"
	t += "3. Trap Abyss: Blade Trap + Void Rift + poison/curse nodes.\n"
	t += "4. Bleed Duelist: Cleave + bleed + corpse spark + execution.\n"
	t += "5. Runaway Contract: Contract Eater + dangerous routes + depth scaling.\n"
	return t

func inventory_text(stats: Dictionary) -> String:
	var t = "INVENTORY / EQUIP TEST\n"
	t += "Press 1-6 to equip an inventory item. Ground items still use E.\n\n"
	if inventory.size() == 0:
		t += "Inventory empty. Open chests, kill elites, or press F for a test drop.\n"
	else:
		for i in range(min(inventory.size(), 6)):
			var it = inventory[i]
			t += str(i + 1) + ") " + it["name"] + " [" + it["rarity"] + " " + it["slot"] + "]\n"
			t += "   " + it["desc"] + "\n"
	t += "\nEQUIPPED\n"
	for slot in equipped.keys():
		var item = equipped[slot]
		t += slot + ": " + (item["name"] if item != null else "-") + "\n"
	return t

func skill_tree_text(stats: Dictionary) -> String:
	if active_skills.size() == 0:
		return "SKILL TREE\nNo skills learned yet. Choose a starting Skill Draft first.\n"
	var skill_name := active_skills[selected_skill]
	var t = "SKILL TREE: " + skill_name + "\n"
	t += "Points: " + str(skill_points.get(skill_name, 0)) + " | XP " + str(int(skill_xp.get(skill_name, 0.0))) + "/" + str(int(skill_xp_next.get(skill_name, 55.0))) + "\n"
	t += "Press 1-9 to unlock a listed node. Select skill with 1-6 when another panel is open or after leaving this panel.\n\n"
	var nodes = SKILL_TREE_NODES[skill_name]
	for i in range(nodes.size()):
		var n = nodes[i]
		var owned := owned_skill_nodes[skill_name].has(n["id"])
		t += str(i + 1) + ") " + ("[OWNED] " if owned else "") + n["name"] + "\n"
		t += "   " + n["desc"] + "\n"
	t += "\nCurrent skill flags: " + ", ".join(owned_skill_nodes[skill_name]) + "\n"
	return t

func dungeon_text(stats: Dictionary) -> String:
	var t = "DUNGEON CONTRACT\n"
	t += "Depth " + str(run_depth) + "/" + str(max_depth) + " | Room " + str(room_index) + " | Cleared " + str(rooms_cleared) + "\n"
	t += "Current: " + str(current_room.get("name", current_room.get("type", "Combat"))) + "\n"
	t += "Biome: " + str(current_room.get("biome", "Ash Crypt")) + " | Threat x" + str(snapped(float(current_room.get("threat", 1.0)), 0.01)) + "\n"
	t += "Mods: " + (", ".join(current_room.get("mods", [])) if current_room.get("mods", []).size() > 0 else "none") + "\n\n"
	t += "ROOM CONTENT\n"
	t += "Obstacles: " + str(obstacles.size()) + " | Traps: " + str(traps.size()) + " | Chests: " + str(chests.size()) + " | Enemies: " + str(enemies.size()) + "\n\n"
	t += "Route choices appear after room clear. Boss appears at final depth.\n"
	return t

func unlock_skill_node_by_index(skill_name: String, idx: int) -> void:
	if not SKILL_TREE_NODES.has(skill_name): return
	var nodes = SKILL_TREE_NODES[skill_name]
	if idx < 0 or idx >= nodes.size(): return
	var node = nodes[idx]
	if owned_skill_nodes[skill_name].has(node["id"]):
		log_msg("Already unlocked: " + node["name"])
		return
	if int(skill_points.get(skill_name, 0)) <= 0:
		log_msg("No " + skill_name + " skill points. Clear rooms, use the skill, or choose Skill Study.")
		return
	skill_points[skill_name] = int(skill_points.get(skill_name, 0)) - 1
	owned_skill_nodes[skill_name].append(node["id"])
	log_msg("Skill node unlocked: " + skill_name + " / " + node["name"])

func find_skill_node(skill_name: String, node_id: String) -> Variant:
	if not SKILL_TREE_NODES.has(skill_name): return null
	for n in SKILL_TREE_NODES[skill_name]:
		if n["id"] == node_id:
			return n
	return null

func gain_skill_xp(skill_name: String, amount: float) -> void:
	if not skill_xp.has(skill_name): return
	skill_xp[skill_name] = float(skill_xp.get(skill_name, 0.0)) + amount
	while float(skill_xp[skill_name]) >= float(skill_xp_next[skill_name]):
		skill_xp[skill_name] = float(skill_xp[skill_name]) - float(skill_xp_next[skill_name])
		skill_xp_next[skill_name] = float(skill_xp_next[skill_name]) * 1.35 + 18.0
		skill_points[skill_name] = int(skill_points.get(skill_name, 0)) + 1
		log_msg(skill_name + " leveled: +1 skill-tree point.")

func interact_or_equip() -> void:
	for i in range(chests.size() - 1, -1, -1):
		if player_pos.distance_to(chests[i]["pos"]) <= 64.0:
			open_chest(i)
			return
	if nearest_loot_index >= 0:
		pickup_nearest_loot()
		return
	log_msg("Nothing close enough to interact with.")

func pickup_nearest_loot() -> void:
	if nearest_loot_index < 0: return
	var item = loot[nearest_loot_index]["item"]
	inventory.append(item)
	loot.remove_at(nearest_loot_index)
	log_msg("Picked up: " + item["name"] + ". Press I then 1-6 to equip.")

func equip_inventory_index(idx: int) -> void:
	if idx < 0 or idx >= inventory.size(): return
	var item = inventory[idx]
	equip_item_direct(item)
	inventory.remove_at(idx)

func equip_item_direct(item: Dictionary) -> void:
	var slot := str(item["slot"])
	if slot == "ring":
		if equipped["ring1"] == null:
			equipped["ring1"] = item
		elif equipped["ring2"] == null:
			equipped["ring2"] = item
		else:
			equipped["ring1"] = item
	else:
		equipped[slot] = item
	log_msg("Equipped: " + item["name"] + " [" + slot + "]")
	var stats := get_stats()
	player_hp = min(player_hp, stats["max_hp"])
	player_mana = min(player_mana, stats["max_mana"])

func open_chest(idx: int) -> void:
	if idx < 0 or idx >= chests.size(): return
	var chest = chests[idx]
	var drops := 2 if chest.get("good", false) else 1
	for i in range(drops):
		_drop_item(chest["pos"] + Vector2(rng.randf_range(-32,32), rng.randf_range(-20,20)), chest.get("good", false))
	chests.remove_at(idx)
	log_msg("Chest opened. Loot dropped.")

func spawn_chest(pos: Vector2, good: bool) -> void:
	chests.append({"pos": clamp_to_arena(pos, 30.0), "good": good})

func place_blade_trap(pos: Vector2, damage: float, tags: Array, stats: Dictionary, scale: float) -> void:
	var radius := 48.0 + stats.get("trap_radius", 0.0)
	traps.append({"pos": clamp_to_arena(pos, radius), "radius": radius * scale, "damage": damage * scale, "tags": tags.duplicate(), "armed": true, "life": 8.0, "owner":"player", "arm_time": 0.18, "color": Color(1.0, 0.78, 0.28, 0.48)})
	if has_flag(stats, "double_trap") and scale >= 1.0:
		traps.append({"pos": clamp_to_arena(player_pos - aim_dir() * 54.0, radius), "radius": radius * 0.62, "damage": damage * 0.62, "tags": tags.duplicate(), "armed": true, "life": 6.0, "owner":"player", "arm_time": 0.25, "color": Color(1.0, 0.78, 0.28, 0.34)})

func _update_room_hazards(delta: float) -> void:
	for i in range(traps.size() - 1, -1, -1):
		var tr = traps[i]
		tr["life"] -= delta
		tr["arm_time"] = max(0.0, float(tr.get("arm_time", 0.0)) - delta)
		if tr["life"] <= 0.0:
			traps.remove_at(i)
			continue
		if tr.get("owner", "room") == "player" and tr["arm_time"] <= 0.0:
			for e in enemies:
				if e["pos"].distance_to(tr["pos"]) <= tr["radius"] + e["radius"]:
					deal_damage(e, tr["damage"], tr["tags"], tr["pos"], "Blade Trap")
					traps.remove_at(i)
					break
		elif tr.get("owner", "room") == "room":
			if player_pos.distance_to(tr["pos"]) <= tr["radius"] + player_radius and invuln_time <= 0.0:
				player_take_damage(float(tr["damage"]), tr["pos"])
				tr["life"] = 0.0

func generate_room_layout(route: Dictionary) -> void:
	var biome := str(route.get("biome", "Ash Crypt"))
	var base_color: Color = ROOM_BIOMES.get(biome, ROOM_BIOMES["Ash Crypt"])["color"]
	var obstacle_count := 3 + rng.randi_range(0, 3) + int(run_depth / 3)
	if route.get("type", "Combat") == "Boss": obstacle_count = 4
	if str(route.get("type", "Combat")) == "Treasure": obstacle_count += 1
	for i in range(obstacle_count):
		var w := rng.randf_range(54, 130)
		var h := rng.randf_range(38, 104)
		var p := Vector2(rng.randf_range(ARENA.position.x + 120, ARENA.end.x - 160), rng.randf_range(ARENA.position.y + 110, ARENA.end.y - 135))
		var r := Rect2(p, Vector2(w, h))
		if r.grow(70).has_point(WORLD_CENTER):
			continue
		obstacles.append({"rect": r, "color": Color(base_color.r + 0.08, base_color.g + 0.08, base_color.b + 0.08)})
	var trap_count := rng.randi_range(1, 3) + int(run_depth / 3)
	var mods: Array = route.get("mods", [])
	if mods.has("Extra Traps") or mods.has("Tight Geometry"):
		trap_count += 2
	if route.get("type", "Combat") == "Boss": trap_count += 2
	for j in range(trap_count):
		var tp := Vector2(rng.randf_range(ARENA.position.x + 90, ARENA.end.x - 90), rng.randf_range(ARENA.position.y + 90, ARENA.end.y - 90))
		if tp.distance_to(WORLD_CENTER) < 130.0: continue
		traps.append({"pos": tp, "radius": rng.randf_range(24, 42), "damage": 8.0 + run_depth * 1.6, "tags": ["Trap", "Area", "Physical"], "armed": true, "life": 999.0, "owner":"room", "arm_time": 0.0, "color": Color(1.0, 0.18, 0.12, 0.34)})

func enemy_pool_for_room(route: Dictionary) -> Array:
	var pool := ["Ash Grunt", "Ash Grunt", "Bone Archer", "Cinder Spitter"]
	var biome := str(route.get("biome", "Ash Crypt"))
	var mods: Array = route.get("mods", [])
	if run_depth >= 2 or route.get("elite", false): pool.append("Iron Brute")
	if biome == "Rot Garden" or mods.has("Rot Hounds"): pool.append("Rot Hound")
	if biome == "Iron Chapel" or mods.has("Armored Patrol"): pool.append("Oathless Knight")
	if biome == "Void Reliquary" or mods.has("Curse Pressure"): pool.append("Mirror Acolyte")
	if biome == "Storm Vault": pool.append("Bone Archer")
	return pool

func random_contract_mod() -> String:
	var mods := ["Extra Traps", "Elite Patrol", "Tight Geometry", "Unstable Shrines", "Projectile Crossfire", "Cursed Reward", "Rot Hounds", "Armored Patrol", "Curse Pressure"]
	return mods[rng.randi_range(0, mods.size() - 1)]

func room_desc(t: String, mods: Array) -> String:
	var d = ""
	match t:
		"Combat": d = "Standard encounter. Balanced XP, loot, and room pressure."
		"Elite": d = "Harder encounter. More enemy density and better drops."
		"Treasure": d = "Smaller fight with guaranteed chest and stronger loot chance."
		"Shrine": d = "Lower enemy count with a passive/build reward direction."
		"Forge": d = "Recovery-oriented room with extra chest chance."
		"Skill Trial": d = "Harder room that grants a skill-tree point upfront."
		"Boss": d = "Final contract door."
		_: d = "Unknown room."
	return d + " Mods: " + (", ".join(mods) if mods.size() > 0 else "none")

func resolve_obstacle_collision(pos: Vector2, radius: float) -> Vector2:
	var out := pos
	for ob in obstacles:
		var r: Rect2 = ob["rect"]
		var nearest := Vector2(clamp(out.x, r.position.x, r.end.x), clamp(out.y, r.position.y, r.end.y))
		var delta := out - nearest
		var dist: float = delta.length()
		if dist < radius and dist > 0.001:
			out += delta.normalized() * (radius - dist + 0.5)
		elif r.has_point(out):
			var left := abs(out.x - r.position.x)
			var right := abs(r.end.x - out.x)
			var top := abs(out.y - r.position.y)
			var bottom := abs(r.end.y - out.y)
			var m := min(min(left, right), min(top, bottom))
			if m == left: out.x = r.position.x - radius
			elif m == right: out.x = r.end.x + radius
			elif m == top: out.y = r.position.y - radius
			else: out.y = r.end.y + radius
	return clamp_to_arena(out, radius)

func point_hits_obstacle(pos: Vector2, radius: float) -> bool:
	for ob in obstacles:
		var r: Rect2 = ob["rect"]
		if r.grow(radius).has_point(pos):
			return true
	return false

func count_enemies_in_radius(pos: Vector2, radius: float) -> int:
	var c := 0
	for e in enemies:
		if e["pos"].distance_to(pos) <= radius + e["radius"]:
			c += 1
	return c

func apply_player_poison(duration: float) -> void:
	# Placeholder player-status hook. For Patch 002 it is represented as immediate chip damage so it cannot softlock UI/state.
	player_hp = max(1.0, player_hp - duration * 1.5)
	floating("poisoned", player_pos + Vector2(0, -46), Color(0.4, 1.0, 0.3))

func _draw_status_pips(e: Dictionary) -> void:
	var offset := -18.0
	for s in e["statuses"].keys():
		draw_circle(e["pos"] + Vector2(offset, e["radius"] + 9.0), 4.0, status_color(s))
		offset += 10.0

func aim_dir() -> Vector2:
	var d = get_global_mouse_position() - player_pos
	if d.length() <= 0.01:
		return Vector2.RIGHT
	return d.normalized()

func vec_from_angle(a: float) -> Vector2:
	return Vector2(cos(a), sin(a))

func clamp_to_arena(p: Vector2, margin: float) -> Vector2:
	return Vector2(clamp(p.x, ARENA.position.x + margin, ARENA.end.x - margin), clamp(p.y, ARENA.position.y + margin, ARENA.end.y - margin))

func has_tag(tags: Array, tag: String) -> bool:
	return tags.has(tag)

func zone_color(tags: Array) -> Color:
	if has_tag(tags, "Fire") or has_tag(tags, "Burn"):
		return Color(1.0, 0.36, 0.10, 0.34)
	if has_tag(tags, "Cold") or has_tag(tags, "Freeze"):
		return Color(0.45, 0.82, 1.0, 0.34)
	if has_tag(tags, "Lightning") or has_tag(tags, "Chain"):
		return Color(0.45, 0.66, 1.0, 0.36)
	if has_tag(tags, "Steam"):
		return Color(0.78, 0.95, 1.0, 0.34)
	if has_tag(tags, "Void") or has_tag(tags, "Curse"):
		return Color(0.58, 0.18, 1.0, 0.34)
	if has_tag(tags, "Poison"):
		return Color(0.34, 0.92, 0.25, 0.32)
	if has_tag(tags, "Trap"):
		return Color(0.92, 0.82, 0.45, 0.32)
	return Color(1.0, 0.82, 0.36, 0.30)

func status_color(s: String) -> Color:
	match s:
		"burn": return Color(1.0, 0.28, 0.08)
		"bleed": return Color(0.86, 0.04, 0.10)
		"freeze": return Color(0.45, 0.82, 1.0)
		"shock": return Color(0.55, 0.65, 1.0)
		"poison": return Color(0.36, 0.92, 0.28)
		"curse": return Color(0.72, 0.32, 1.0)
		_: return Color(1.0, 1.0, 1.0)

func rarity_color(r: String) -> Color:
	match r:
		"Common": return Color(0.82, 0.82, 0.82)
		"Magic": return Color(0.38, 0.62, 1.0)
		"Rare": return Color(0.92, 0.74, 0.26)
		"Legendary": return Color(1.0, 0.38, 0.12)
		"Mythic": return Color(1.0, 0.22, 0.86)
		_: return Color(1.0, 1.0, 1.0)
